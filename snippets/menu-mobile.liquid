{%- comment -%}
  Mobile drawer — category-row accordion (v4)
  Accepts:
    menu        — linklist (required)
    logo        — image (optional)
    logo_width  — number (optional)

  Structure:
    Sub panel (always shown on drawer open):
      - Plain text category rows with > chevron
      - Tap a row → inline 3-column product grid expands below it (accordion)
      - Footer: Shop-all CTA, reviews ribbon, locale switcher

  Products are resolved from each category's collection link at render time
  and hidden/shown via Alpine's x-show. No sub-sub panel navigation.

  Close X lives in the page header (see sections/header.liquid and
  assets/header-overrides.css).
{%- endcomment -%}

<div class="relative mobile-menu mobile-menu--v2"
     :class="{
       'mobile-menu--v2-sub-active': activeMenu > 0,
     }"
     x-data="{
      activeMenu: 1,
      expandedCategory: -1,
      get isActive() { return this.activeMenu },
      setActive(_sel) { this.activeMenu = _sel == this.activeMenu ? 0 : _sel },
      toggleCategory(_i) {
        this.expandedCategory = (this.expandedCategory == _i) ? -1 : _i;
      },
      closeDrawer() {
        var d = document.querySelector('#Details-menu-drawer-container');
        if (d) d.removeAttribute('open');
        document.body.classList.remove('noscroll');
        document.body.classList.remove('menu-opening');
        this.activeMenu = 1;
        this.expandedCategory = -1;
      },
      init() {
        var details = document.querySelector('#Details-menu-drawer-container');
        if (details) {
          var self = this;
          details.addEventListener('toggle', function() {
            if (!details.open) {
              self.activeMenu = 1;
              self.expandedCategory = -1;
            }
          });
        }
      },
    }"
    x-transition.scale>

  {%- comment -%} ============ SUBMENU PANELS ============ {%- endcomment -%}
  {%- for link in menu.links -%}
    {%- if link.links.size > 0 -%}
      <div class="mobile-navigation mobile-menu__panel mobile-menu__panel--sub w-full bg-white absolute top-0 z-30"
        x-show="(isActive == {{ forloop.index }})"
        x-transition:enter-end="left-0"
        x-transition:enter-start="-left-full"
        x-transition:enter="transition-all ease-out duration-200"
        x-transition:leave-end="-left-full"
        x-transition:leave-start="left-0"
        x-transition:leave="transition-all ease-in duration-200">

        <div class="mobile-menu__body mobile-menu__body--sub flex flex-col">

          {%- comment -%} Category accordion list {%- endcomment -%}
          <ul class="mobile-menu__cat-list">
            {%- for sub_link in link.links -%}

              {%- comment -%} Resolve collection from sub_link {%- endcomment -%}
              {%- assign mob_coll = blank -%}
              {%- assign mob_has_coll = false -%}
              {%- if sub_link.type == 'collection_link' and sub_link.object.products.size > 0 -%}
                {%- assign mob_coll = sub_link.object -%}
                {%- assign mob_has_coll = true -%}
              {%- endif -%}
              {%- if mob_has_coll == false and sub_link.url contains '/collections/' -%}
                {%- assign mob_handle = sub_link.url | split: '/collections/' | last -%}
                {%- assign mob_handle = mob_handle | split: '?' | first -%}
                {%- assign mob_handle = mob_handle | split: '#' | first -%}
                {%- assign mob_handle = mob_handle | split: '/' | first -%}
                {%- if mob_handle != blank -%}
                  {%- assign mob_candidate = collections[mob_handle] -%}
                  {%- if mob_candidate.products.size > 0 -%}
                    {%- assign mob_coll = mob_candidate -%}
                    {%- assign mob_has_coll = true -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}

              <li class="mobile-menu__cat-item">
                {%- if mob_has_coll -%}
                  {%- comment -%} Accordion toggle row {%- endcomment -%}
                  <div class="mobile-menu__cat-row"
                       @click="toggleCategory({{ forloop.index }})"
                       @keydown.enter.prevent="toggleCategory({{ forloop.index }})"
                       @keydown.space.prevent="toggleCategory({{ forloop.index }})"
                       role="button"
                       tabindex="0"
                       :aria-expanded="expandedCategory == {{ forloop.index }} ? 'true' : 'false'">
                    <span class="mobile-menu__cat-name">{{ sub_link.title }}</span>
                    <svg class="mobile-menu__cat-chevron"
                         :class="expandedCategory == {{ forloop.index }} ? 'is-open' : ''"
                         width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>

                  {%- comment -%} Inline product grid {%- endcomment -%}
                  <div class="mobile-menu__products-grid"
                       x-show="expandedCategory == {{ forloop.index }}"
                       x-cloak>
                    {%- assign mob_tile_limit = 5 -%}
                    {%- if mob_coll.products.size <= 5 -%}
                      {%- assign mob_tile_limit = mob_coll.products.size -%}
                    {%- endif -%}
                    {%- for product in mob_coll.products limit: mob_tile_limit -%}
                      <a class="mobile-menu__product-card" href="{{ product.url }}">
                        <div class="mobile-menu__product-img">
                          {%- if product.featured_image != blank -%}
                            <img
                              src="{{ product.featured_image | image_url: width: 300 }}"
                              srcset="{{ product.featured_image | image_url: width: 150 }} 150w, {{ product.featured_image | image_url: width: 300 }} 300w"
                              sizes="30vw"
                              alt="{{ product.featured_image.alt | default: product.title | escape }}"
                              loading="lazy"
                              class="mobile-menu__product-img-el"
                              width="{{ product.featured_image.width }}"
                              height="{{ product.featured_image.height }}">
                          {%- endif -%}
                        </div>
                        <div class="mobile-menu__product-title">{{ product.title | escape }}</div>
                      </a>
                    {%- endfor -%}
                    <a class="mobile-menu__product-card mobile-menu__product-card--shop-all" href="{{ mob_coll.url }}">
                      <div class="mobile-menu__product-img mobile-menu__product-img--shop-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                          <path d="M6 14h16m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <div class="mobile-menu__product-title">Shop all</div>
                    </a>
                  </div>

                {%- else -%}
                  {%- comment -%} Direct link (no collection resolved) {%- endcomment -%}
                  <a class="mobile-menu__cat-row mobile-menu__cat-row--link" href="{{ sub_link.url }}">
                    <span class="mobile-menu__cat-name">{{ sub_link.title }}</span>
                    <svg class="mobile-menu__cat-chevron" width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>

          {%- comment -%} CTA: "Shop all" for the top-level menu {%- endcomment -%}
          <div class="mobile-menu__cta-wrap">
            {% assign link_title_lower = link.title | downcase | strip %}
            {% if link_title_lower == 'shop' %}
              <a class="mobile-menu__cta" href="{{ routes.collections_url }}/all">
                Shop all products
              </a>
            {% else %}
              <a class="mobile-menu__cta" href="{{ link.url }}">
                Shop {{ link.title }}
              </a>
            {% endif %}
          </div>

          <div class="mobile-menu__footer">
            <a class="mobile-menu__reviews-ribbon"
               href="https://www.reviews.io/company-reviews/store/sockeloen-nl"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Read our reviews on REVIEWS.io">
              <span class="mobile-menu__reviews-stars" role="img" aria-label="Rated 5 stars">
                {% for i in (1..5) %}
                  <span class="mobile-menu__reviews-star" aria-hidden="true">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/></svg>
                  </span>
                {% endfor %}
              </span>
              <span class="mobile-menu__reviews-text"><strong>2,410</strong> reviews</span>
              <img class="mobile-menu__reviews-logo"
                src="https://assets.reviews.io/img/all-global-assets/logo/reviewsio-logo.svg"
                alt="REVIEWS.io"
                width="72" height="16" loading="lazy">
            </a>

            <div class="mobile-menu__locale" x-data="{ localeOpen: false }">
              <div @click="localeOpen = !localeOpen"
                   @keydown.enter.prevent="localeOpen = !localeOpen"
                   @keydown.space.prevent="localeOpen = !localeOpen"
                   role="button"
                   tabindex="0"
                   :aria-expanded="localeOpen ? 'true' : 'false'"
                   class="mobile-menu__locale-toggle">
                <svg class="mobile-menu__locale-globe" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                <span>{{ localization.language.iso_code | upcase }} / {{ localization.country.currency.iso_code | upcase }}</span>
                <svg class="mobile-menu__locale-chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" xmlns="http://www.w3.org/2000/svg" :class="localeOpen && 'is-open'">
                  <path d="M4 5L8 0.833333L7.2 8.58591e-08L4 3.33333L0.8 9.5399e-09L4.9687e-08 0.833333L4 5Z" fill="currentColor"/>
                </svg>
              </div>
              <ul x-show="localeOpen" x-transition class="mobile-menu__locale-list">
                <li><a href="#" data-country-code="NL" data-language="en" class="mobile-locale-link{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'EUR' %} is-active{% endif %}">EN / EUR</a></li>
                <li><a href="#" data-country-code="NL" data-language="nl" class="mobile-locale-link{% if localization.language.iso_code == 'nl' %} is-active{% endif %}">NL / EUR</a></li>
                <li><a href="#" data-country-code="DE" data-language="de" class="mobile-locale-link{% if localization.language.iso_code == 'de' %} is-active{% endif %}">DE / EUR</a></li>
                <li><a href="#" data-country-code="NL" data-language="fr" class="mobile-locale-link{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'EUR' %} is-active{% endif %}">FR / EUR</a></li>
                <li><a href="#" data-country-code="US" data-language="en" class="mobile-locale-link{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'USD' %} is-active{% endif %}">EN / USD</a></li>
                <li><a href="#" data-country-code="US" data-language="fr" class="mobile-locale-link{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'USD' %} is-active{% endif %}">FR / USD</a></li>
              </ul>
              {%- form 'localization', id: 'MobileLocalizationForm', class: 'hidden' -%}
                <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
                <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
              {%- endform -%}
            </div>
          </div>

        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  document.addEventListener('click', function(e) {
    var link = e.target.closest('.mobile-locale-link');
    if (!link) return;
    e.preventDefault();
    var form = document.getElementById('MobileLocalizationForm');
    if (!form) return;
    form.querySelector('[name="country_code"]').value = link.dataset.countryCode;
    form.querySelector('[name="locale_code"]').value = link.dataset.language;
    form.submit();
  });
</script>
