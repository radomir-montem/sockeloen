{%- comment -%}
  Mobile drawer — Cloudpillo-style redesign (v3: root-skipped)
  Accepts:
    menu        — linklist (required)
    logo        — image (optional, used as the sub-panel wordmark fallback only)
    logo_width  — number (optional)

  Structure (root panel was removed — SHOP is no longer a navigation step):
    Sub panel (ALWAYS shown on drawer open): card grid → locale/reviews footer
    Sub-sub panel: replaces sub via overlay when user taps a card with children

  Close / back affordances live in the page header (see sections/header.liquid
  and the overrides in assets/header-overrides.css):
    - Close X on left: the stock <summary> hamburger, restyled as a round
      white pill only while the drawer is open. Clicking it toggles the
      <details> and closes the drawer.
    - Back arrow on right: shown only when childMenu > 0, replaces the
      cart/search icons. Clicking it dispatches a `drawer:back` CustomEvent
      which this Alpine scope handles.

  Cards auto-enrich from section.blocks matched by link.title (or per-locale
  title). Links without a matched block fall back to title-only.
{%- endcomment -%}

<div class="relative mobile-menu mobile-menu--v2"
     :class="{
       'mobile-menu--v2-sub-active': activeMenu > 0 && childMenu == 0,
       'mobile-menu--v2-subsub-active': childMenu > 0
     }"
     x-data="{
      /* Panel state:
           activeMenu = N  → sub panel for menu.links[N-1] (forloop.index is 1-based)
           childMenu  = N  → sub-sub panel for sub_link N (nested inside the active sub)
           childMenu  = 0  → no sub-sub shown, user is browsing the sub cards
         Default activeMenu = 1 because root panel is gone — sub is the entry point. */
      activeMenu: 1,
      childMenu: 0,
      get isActive() { return this.activeMenu },
      get isChild() { return this.childMenu },
      setActive(_sel) { this.activeMenu = _sel == this.activeMenu ? 0 : _sel },
      setChild(_sel) {
        this.childMenu = _sel == this.childMenu ? 0 : _sel;
        /* Keep the body class in lockstep so the page header can swap
           cart/search for the back arrow without a flash. */
        document.body.classList.toggle('drawer-subsub-active', this.childMenu > 0);
      },
      closeDrawer() {
        var d = document.querySelector('#Details-menu-drawer-container');
        if (d) d.removeAttribute('open');
        document.body.classList.remove('noscroll');
        document.body.classList.remove('menu-opening');
        document.body.classList.remove('drawer-subsub-active');
        /* Always land on the sub entry point next time. */
        this.activeMenu = 1;
        this.childMenu = 0;
      },
      init() {
        /* The stock drawer can close via the header's <summary> toggle
           (clicking the hamburger/X while open). We never get a hook into
           that through Alpine, so mirror the <details> toggle event and
           reset nested state when the drawer closes. */
        var details = document.querySelector('#Details-menu-drawer-container');
        if (details) {
          var self = this;
          details.addEventListener('toggle', function() {
            if (!details.open) {
              self.activeMenu = 1;
              self.childMenu = 0;
              document.body.classList.remove('drawer-subsub-active');
            }
          });
        }
      },
    }"
    @drawer:back.window="setChild(0)"
    x-transition.scale>

  {%- comment -%} ============ SUBMENU PANELS (entry point — no root anymore) ============ {%- endcomment -%}
  {%- for link in menu.links -%}
    {%- if link.links.size > 0 -%}
      <div class="mobile-navigation mobile-menu__panel mobile-menu__panel--sub w-full bg-white absolute top-0 z-30"
        x-show="(isActive == {{ forloop.index }})"
        x-transition:enter-end="left-0"
        x-transition:enter-start="-left-full"
        x-transition:enter="transition-all ease-out duration-200"
        x-transition:leave-end="-left-full"
        x-transition:leave-start="left-0"
        x-transition:leave="transition-all ease-in duration-200">

        <div class="mobile-menu__body mobile-menu__body--sub flex flex-col">

          {%- comment -%} Scrollable card list {%- endcomment -%}
          <ul class="mobile-menu__cards">
            {%- for sub_link in link.links -%}
              {% assign has_childlinks = false %}
              {% assign sub_link_url = sub_link.url %}
              {%- if sub_link.links.size > 0 -%}
                {% assign has_childlinks = true %}
                {% assign sub_link_url = '#' %}
              {%- endif -%}

              {%- comment -%} Find matching block by link.title (handles all 4 locale titles) {%- endcomment -%}
              {% assign matched_block = nil %}
              {% for b in section.blocks %}
                {% if sub_link.title == b.settings.title
                   or sub_link.title == b.settings.title_translate
                   or sub_link.title == b.settings.title_translate_german
                   or sub_link.title == b.settings.title_translate_french %}
                  {% assign matched_block = b %}
                {% endif %}
              {% endfor %}

              {%- comment -%} Resolve localized feature text {%- endcomment -%}
              {% assign feat_text = blank %}
              {% if matched_block %}
                {% assign feat_text = matched_block.settings.feature_text %}
                {% if localization.language.iso_code == 'nl' and matched_block.settings.feature_text_nl != blank %}{% assign feat_text = matched_block.settings.feature_text_nl %}{% endif %}
                {% if localization.language.iso_code == 'de' and matched_block.settings.feature_text_de != blank %}{% assign feat_text = matched_block.settings.feature_text_de %}{% endif %}
                {% if localization.language.iso_code == 'fr' and matched_block.settings.feature_text_fr != blank %}{% assign feat_text = matched_block.settings.feature_text_fr %}{% endif %}
              {% endif %}

              <li class="mobile-menu__card-wrap">
                <a class="mobile-menu__card{% if has_childlinks %} mobile-menu__card--has-children{% endif %}"
                   href="{{ sub_link_url }}"
                   {% if has_childlinks %}@click.prevent="setChild({{ forloop.index }})"{% endif %}>
                  <div class="mobile-menu__card-img">
                    {% if matched_block.settings.image_item != blank %}
                      {%- render 'c-image-element',
                        image: matched_block.settings.image_item,
                        lazy: true,
                        class: "mobile-menu__card-img-el"
                      -%}
                    {% endif %}
                  </div>
                  <div class="mobile-menu__card-body">
                    <div class="mobile-menu__card-title">{{ sub_link.title }}</div>
                    {% if feat_text != blank %}
                      <div class="mobile-menu__card-feature">
                        {% if matched_block.settings.feature_icon != blank %}
                          <span class="mobile-menu__card-icon">
                            {%- render 'c-image-element',
                              image: matched_block.settings.feature_icon,
                              lazy: true,
                              class: "mobile-menu__card-icon-el"
                            -%}
                          </span>
                        {% endif %}
                        <span class="mobile-menu__card-feature-text">{{ feat_text }}</span>
                      </div>
                    {% endif %}
                  </div>
                  {% if has_childlinks %}
                    <svg class="mobile-menu__card-chevron" width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {% endif %}
                </a>
              </li>
            {% endfor %}
          </ul>

          {%- comment -%}
            Sub panel footer: "Shop all" CTA, reviews ribbon, locale pill.
            These used to live in the (now-removed) root panel. We moved
            them into the sub panel so they're still reachable since sub
            is the new entry point.
          {%- endcomment -%}
          <div class="mobile-menu__cta-wrap">
            <a class="mobile-menu__cta" href="{{ link.url }}">
              Shop {{ link.title }}
            </a>
          </div>

          <div class="mobile-menu__footer">
            <a class="mobile-menu__reviews-ribbon"
               href="https://www.reviews.io/company-reviews/store/sockeloen-nl"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Read our reviews on REVIEWS.io">
              <span class="mobile-menu__reviews-stars" role="img" aria-label="Rated 5 stars">
                {% for i in (1..5) %}
                  <span class="mobile-menu__reviews-star" aria-hidden="true">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/></svg>
                  </span>
                {% endfor %}
              </span>
              <span class="mobile-menu__reviews-text"><strong>2,410</strong> reviews on</span>
              <img class="mobile-menu__reviews-logo"
                src="https://assets.reviews.io/img/all-global-assets/logo/reviewsio-logo.svg"
                alt="REVIEWS.io"
                width="72" height="16" loading="lazy">
            </a>

            <div class="mobile-menu__locale" x-data="{ localeOpen: false }">
              {%- comment -%}
                Intentionally a <div role="button"> instead of <button>. The
                theme's MenuDrawer custom element (global.js) binds
                  `this.querySelectorAll('button').forEach(b => b.addEventListener('click', this.onCloseButtonClick.bind(this)))`
                on construction — any <button> inside the drawer would be
                treated as a submenu-close trigger, which closes the whole
                drawer ~400ms after toggling localeOpen. Using a div keeps
                the selector-miss. Keyboard support is restored via
                @keydown.enter / @keydown.space.
              {%- endcomment -%}
              <div @click="localeOpen = !localeOpen"
                   @keydown.enter.prevent="localeOpen = !localeOpen"
                   @keydown.space.prevent="localeOpen = !localeOpen"
                   role="button"
                   tabindex="0"
                   :aria-expanded="localeOpen ? 'true' : 'false'"
                   class="mobile-menu__locale-toggle">
                <svg class="mobile-menu__locale-globe" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                <span>{{ localization.language.iso_code | upcase }} / {{ localization.country.currency.iso_code | upcase }}</span>
                <svg class="mobile-menu__locale-chevron" width="8" height="5" viewBox="0 0 8 5" fill="none" xmlns="http://www.w3.org/2000/svg" :class="localeOpen && 'is-open'">
                  <path d="M4 5L8 0.833333L7.2 8.58591e-08L4 3.33333L0.8 9.5399e-09L4.9687e-08 0.833333L4 5Z" fill="currentColor"/>
                </svg>
              </div>
              <ul x-show="localeOpen" x-transition class="mobile-menu__locale-list">
                <li><a href="#" data-country-code="NL" data-language="en" class="mobile-locale-link{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'EUR' %} is-active{% endif %}">EN / EUR</a></li>
                <li><a href="#" data-country-code="NL" data-language="nl" class="mobile-locale-link{% if localization.language.iso_code == 'nl' %} is-active{% endif %}">NL / EUR</a></li>
                <li><a href="#" data-country-code="DE" data-language="de" class="mobile-locale-link{% if localization.language.iso_code == 'de' %} is-active{% endif %}">DE / EUR</a></li>
                <li><a href="#" data-country-code="NL" data-language="fr" class="mobile-locale-link{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'EUR' %} is-active{% endif %}">FR / EUR</a></li>
                <li><a href="#" data-country-code="US" data-language="en" class="mobile-locale-link{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'USD' %} is-active{% endif %}">EN / USD</a></li>
                <li><a href="#" data-country-code="US" data-language="fr" class="mobile-locale-link{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'USD' %} is-active{% endif %}">FR / USD</a></li>
              </ul>
              {%- form 'localization', id: 'MobileLocalizationForm', class: 'hidden' -%}
                <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
                <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
              {%- endform -%}
            </div>
          </div>

        </div>
      </div>

      {%- comment -%}
        ============ SUB-SUBMENU PANELS (level 3) ============
        Rendered as SIBLINGS of the sub panel (not nested inside its
        body) so we can hide the sub panel via display:none when
        childMenu > 0 without also hiding the subsub that should take
        its place. The subsub panel is absolute-positioned inside the
        wrap (matches .mobile-menu__panel--sub's layout), and when
        subsub-active our CSS flips it to position:relative so it
        contributes height and sizes the drawer.
      {%- endcomment -%}
      {% for sub_link in link.links %}
        {% if sub_link.links.size > 0 %}
          {%- comment -%}
            x-transition intentionally omitted. The Tailwind class-swap
            transition used on the sub panel (-left-full → left-0) stalled
            for the subsub — Alpine would add enter-start + enter classes
            but never advance to enter-end, leaving the panel locked at
            `left: -100%`. Dropping the transition makes the overlay flip
            instantly, which matches the "replace" feel the user asked
            for anyway. We still use `left: 0` from `left-0` so the panel
            is positioned correctly when visible.
          {%- endcomment -%}
          <div class="mobile-navigation mobile-menu__panel mobile-menu__panel--subsub w-full bg-white absolute top-0 left-0 z-30"
               x-show="childMenu == {{ forloop.index }}"
               x-cloak>

            <div class="mobile-menu__body mobile-menu__body--subsub flex flex-col">
              <ul class="mobile-menu__cards">
                {%- for grandchild in sub_link.links -%}
                  {% assign g_block = nil %}
                  {% for b in section.blocks %}
                    {% if grandchild.title == b.settings.title
                       or grandchild.title == b.settings.title_translate
                       or grandchild.title == b.settings.title_translate_german
                       or grandchild.title == b.settings.title_translate_french %}
                      {% assign g_block = b %}
                    {% endif %}
                  {% endfor %}

                  {% assign g_feat = blank %}
                  {% if g_block %}
                    {% assign g_feat = g_block.settings.feature_text %}
                    {% if localization.language.iso_code == 'nl' and g_block.settings.feature_text_nl != blank %}{% assign g_feat = g_block.settings.feature_text_nl %}{% endif %}
                    {% if localization.language.iso_code == 'de' and g_block.settings.feature_text_de != blank %}{% assign g_feat = g_block.settings.feature_text_de %}{% endif %}
                    {% if localization.language.iso_code == 'fr' and g_block.settings.feature_text_fr != blank %}{% assign g_feat = g_block.settings.feature_text_fr %}{% endif %}
                  {% endif %}

                  <li class="mobile-menu__card-wrap">
                    <a class="mobile-menu__card" href="{{ grandchild.url }}">
                      <div class="mobile-menu__card-img">
                        {% if g_block.settings.image_item != blank %}
                          {%- render 'c-image-element',
                            image: g_block.settings.image_item,
                            lazy: true,
                            class: "mobile-menu__card-img-el"
                          -%}
                        {% endif %}
                      </div>
                      <div class="mobile-menu__card-body">
                        <div class="mobile-menu__card-title">{{ grandchild.title }}</div>
                        {% if g_feat != blank %}
                          <div class="mobile-menu__card-feature">
                            {% if g_block.settings.feature_icon != blank %}
                              <span class="mobile-menu__card-icon">
                                {%- render 'c-image-element',
                                  image: g_block.settings.feature_icon,
                                  lazy: true,
                                  class: "mobile-menu__card-icon-el"
                                -%}
                              </span>
                            {% endif %}
                            <span class="mobile-menu__card-feature-text">{{ g_feat }}</span>
                          </div>
                        {% endif %}
                      </div>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>

              <div class="mobile-menu__cta-wrap">
                <a class="mobile-menu__cta" href="{{ sub_link.url }}">
                  Shop {{ sub_link.title }}
                </a>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  document.addEventListener('click', function(e) {
    var link = e.target.closest('.mobile-locale-link');
    if (!link) return;
    e.preventDefault();
    var form = document.getElementById('MobileLocalizationForm');
    if (!form) return;
    form.querySelector('[name="country_code"]').value = link.dataset.countryCode;
    form.querySelector('[name="locale_code"]').value = link.dataset.language;
    form.submit();
  });
</script>
