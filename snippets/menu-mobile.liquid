<div class="relative" x-data="{
      activeMenu: 1,
      childMenu: 0,
      collectionMenu: 0,
      get isActive() {
        return this.activeMenu 
      },
      get isChild() {
        return this.childMenu 
      },
      get isCollection() {
        return this.collectionMenu 
      },
      setActive(_sel) {
        this.activeMenu = _sel == this.activeMenu ? 0 : _sel 
      },
      setChild(_sel) {
        this.childMenu = _sel == this.childMenu ? 0 : _sel 
      },
      setCollection(_sel) {
        this.collectionMenu = _sel == this.collectionMenu ? 0 : _sel 
      },
    }" x-transition.scale>

  <div class="mobile-navigation h-full w-full bg-white absolute top-0 z-30 overflow-auto"
    x-show="(isActive == {{ forloop.index }})"
    x-transition:enter-end="left-0"
    x-transition:enter-start="-left-full"
    x-transition:enter="transition-all ease-out duration-200"
    x-transition:leave-end="-left-full"
    x-transition:leave-start="left-0"
    x-transition:leave="transition-all ease-in duration-200">
    <div class="mobile-menu__panel px-[32px] py-[64px] flex flex-col">
      <ul>
        {%- for link in menu.links -%}
          {% assign has_links = false %}
          {% assign link_url = link.url %}
          {%- if link.links.size > 0 -%}
            {% assign has_links = true %}
            {% assign link_url = '#' %}
          {%- endif -%}
          <li class="text-[20px] text-[#111111] mb-[32px]" data-item-title="{{ link.title | escape }}" >
            <a class="text-[20px] text-[#111111] font-bold flex items-center justify-between"
              href="{{ link_url }}"
              {% if link.title == 'SALE' %}style="color: #ff0000"{% endif %}
              {% if has_links %} @click="setActive({{forloop.index }})" {% endif %}>
              {{- link.title -}}
              {%- if has_links -%}{% render 'icon-arrow-right' %}{%- endif -%}
            </a>
          </li>
        {% endfor %}
      </ul>

      {%- comment -%} Language / currency switcher {%- endcomment -%}
      <div class="mobile-menu__locale mt-auto pt-8 border-t border-[#e5e5e5]" x-data="{ localeOpen: false }">
        <button
          @click="localeOpen = !localeOpen"
          class="flex items-center gap-2 text-[14px] text-[#666] tracking-[0.04em] uppercase"
          type="button"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span>{{ localization.language.iso_code | upcase }} / {{ localization.country.currency.iso_code | upcase }}</span>
          <svg width="8" height="5" viewBox="0 0 8 5" fill="none" xmlns="http://www.w3.org/2000/svg" :class="localeOpen && 'rotate-180'" class="transition-transform duration-200">
            <path d="M4 5L8 0.833333L7.2 8.58591e-08L4 3.33333L0.8 9.5399e-09L4.9687e-08 0.833333L4 5Z" fill="currentColor"/>
          </svg>
        </button>
        <ul x-show="localeOpen" x-transition class="mt-3 mb-2 rounded-sm border border-[#e5e5e5] overflow-hidden bg-white">
          <li><a href="#" data-country-code="NL" data-language="en" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'EUR' %} !text-black !font-bold{% endif %}">EN / EUR</a></li>
          <li><a href="#" data-country-code="NL" data-language="nl" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'nl' %} !text-black !font-bold{% endif %}">NL / EUR</a></li>
          <li><a href="#" data-country-code="DE" data-language="de" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'de' %} !text-black !font-bold{% endif %}">DE / EUR</a></li>
          <li><a href="#" data-country-code="NL" data-language="fr" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'EUR' %} !text-black !font-bold{% endif %}">FR / EUR</a></li>
          <li><a href="#" data-country-code="US" data-language="en" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'en' and localization.country.currency.iso_code == 'USD' %} !text-black !font-bold{% endif %}">EN / USD</a></li>
          <li><a href="#" data-country-code="US" data-language="fr" class="mobile-locale-link block px-4 py-[12px] text-[13px] tracking-[0.04em] text-[#333] hover:bg-[#f0f0f0] transition-colors{% if localization.language.iso_code == 'fr' and localization.country.currency.iso_code == 'USD' %} !text-black !font-bold{% endif %}">FR / USD</a></li>
        </ul>
        {%- form 'localization', id: 'MobileLocalizationForm', class: 'hidden' -%}
          <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
          <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
        {%- endform -%}
      </div>
    </div>
    {%- for link in menu.links -%}
      {%- if link.links.size > 0 -%}
        <div class="mobile-navigation w-full bg-white absolute top-0 z-30"
          style="height: 100vh"
          x-show="(isActive == {{ forloop.index }})"
          x-transition:enter-end="left-0"
          x-transition:enter-start="-left-full"
          x-transition:enter="transition-all ease-out duration-200"
          x-transition:leave-end="-left-full"
          x-transition:leave-start="left-0"
          x-transition:leave="transition-all ease-in duration-200">
          {% comment %} <div @click="setActive(0)" class="px-5 py-4 flex flex-row items-center cursor-pointer">
            <div>
              {%- render 'icon-arraw-left', class: 'mr-[8px]' -%}
            </div>
            <div class="text-[14px] text-[#111111]">Back</div>
          </div> {% endcomment %}
          <ul class="px-[32px] py-[23px]">
            {% for sub_link in link.links %}
                {% assign has_childlinks = false %}
                {% assign sub_link_url = sub_link.url %}
                {%- if sub_link.links.size > 0 -%}
                  {% assign has_childlinks = true %}
                  {% assign sub_link_url = '#' %}
                {%- endif -%}
                <li class="mb-[32px]">
                  <a class="text-[20px] text-[#111111] font-bold flex items-center justify-between" href="{{ sub_link_url }}"
                {% if has_childlinks %} @click="setChild({{forloop.index }})" {% endif %}>
                    {{- sub_link.title -}}
                {%- if has_childlinks -%}{% render 'icon-arrow-right' %}{%- endif -%}
                  </a>
                </li>
            {% endfor %}
          </ul>
          {% for sub_link in link.links %}
            <div class="mobile-navigation w-full bg-white absolute top-0 z-30"
              style="height: 100vh"
              x-show="(isChild == {{ forloop.index }})"
              x-transition:enter-end="left-0"
              x-transition:enter-start="-left-full"
              x-transition:enter="transition-all ease-out duration-200"
              x-transition:leave-end="-left-full"
              x-transition:leave-start="left-0"
              x-transition:leave="transition-all ease-in duration-200">
              <div @click="setChild(0)" class="px-5 py-4 flex flex-row items-center cursor-pointer">
                <div>
                  {%- render 'icon-arraw-left', class: 'mr-[8px]' -%}
                </div>
                <div class="text-[14px] text-[#111111]">Back</div>
              </div>
              <ul class="px-[32px] py-[23px]">
                {%- for grandchildlink in sub_link.links -%}
                  <li class="mb-[32px]">
                      <a 
                      href="{{grandchildlink.url}}" class="text-[20px] submenu-img text-[#111111] font-bold uppercase flex items-center justify-start">
                      {% for block in section.blocks %}
                        {% assign collection = block.settings.title %}
                        {% assign collection_translated = block.settings.title_translate %}
                        {% if grandchildlink.title == collection or grandchildlink.title == collection_translated %}
                          {%- render 'c-image-element',
                            image: block.settings.image_item,
                            lazy: true,
                            class: "w-[60px] h-[70px] object-contain mr-[16px] bg-[#E2E2E2]"
                          -%}
                        {% endif %}
                      {% endfor %}
                        <span class="w-[71%]">{{ grandchildlink.title }}</span>
                      </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {% endfor %}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('click', function(e) {
    var link = e.target.closest('.mobile-locale-link');
    if (!link) return;
    e.preventDefault();
    var form = document.getElementById('MobileLocalizationForm');
    if (!form) return;
    form.querySelector('[name="country_code"]').value = link.dataset.countryCode;
    form.querySelector('[name="locale_code"]').value = link.dataset.language;
    form.submit();
  });
</script>