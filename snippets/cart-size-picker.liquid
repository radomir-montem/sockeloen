{% comment %}
  Quick size picker popup for cart drawer cross-sells.
  Rendered once inside cart-drawer, populated dynamically via JS.
{% endcomment %}

<div id="cart-size-picker" class="cart-size-picker" style="display:none;">
  <div class="cart-size-picker__overlay" onclick="window.cartSizePicker.close()"></div>
  <div class="cart-size-picker__panel">
    <div class="cart-size-picker__header">
      <div class="cart-size-picker__product-info">
        <img id="cart-size-picker-img" src="" alt="" width="60" height="60" loading="lazy">
        <div>
          <p id="cart-size-picker-title" class="cart-size-picker__title"></p>
          <p id="cart-size-picker-price" class="cart-size-picker__price"></p>
        </div>
      </div>
      <button type="button" class="cart-size-picker__close" onclick="window.cartSizePicker.close()" aria-label="{{ 'accessibility.close' | t }}">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div id="cart-size-picker-options" class="cart-size-picker__options"></div>

    <button type="button" id="cart-size-picker-confirm" class="cart-size-picker__confirm" disabled onclick="window.cartSizePicker.addToCart()">
      {{ 'sections.cart.add' | t }}
    </button>

    <div id="cart-size-picker-loading" class="cart-size-picker__loading" style="display:none;">
      <svg class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
    </div>
  </div>
</div>

<script>
  window.cartSizePicker = {
    data: null,
    selectedVariantId: null,
    selectedOptions: {},

    /* Find the first image associated with a variant that has a specific option value */
    getVariantImage: function(product, optIndex, optValue) {
      var variant = product.variants.find(function(v) {
        return v['option' + (optIndex + 1)] === optValue;
      });
      if (!variant) return null;

      if (variant.featured_image) {
        var fiSrc = typeof variant.featured_image === 'string' ? variant.featured_image : variant.featured_image.src;
        if (fiSrc) return fiSrc.replace(/(\.[^.]+)$/, '_80x$1');
      }

      if (product.images && product.images.length > 0) {
        var firstImg = product.images[0];
        if (typeof firstImg === 'object' && firstImg.variant_ids) {
          var img = product.images.find(function(im) {
            return im.variant_ids && im.variant_ids.indexOf(variant.id) !== -1;
          });
          if (img && img.src) return img.src.replace(/(\.[^.]+)$/, '_80x$1');
        }
      }
      return null;
    },

    isColorOption: function(optName) {
      var name = optName.toLowerCase();
      return name === 'color' || name === 'colour' || name === 'kleur';
    },

    open: function(btn) {
      var self = this;
      var url = btn.getAttribute('data-product-url');
      if (!url) { console.error('Size picker: no data-product-url'); return; }

      var disabledAttr = btn.getAttribute('data-disabled-variants') || '';
      var disabledVariantIds = disabledAttr ? disabledAttr.split(',').map(function(id) { return parseInt(id, 10); }) : [];

      var picker = document.getElementById('cart-size-picker');
      var loading = document.getElementById('cart-size-picker-loading');
      var optionsContainer = document.getElementById('cart-size-picker-options');
      var confirmBtn = document.getElementById('cart-size-picker-confirm');

      picker.style.display = 'flex';
      loading.style.display = 'flex';
      optionsContainer.innerHTML = '';
      confirmBtn.disabled = true;
      self.selectedVariantId = null;
      self.selectedOptions = {};
      self.data = null;
      self.disabledVariantIds = disabledVariantIds;

      fetch(url)
        .then(function(r) {
          if (!r.ok) throw new Error('Product fetch failed: ' + r.status);
          return r.json();
        })
        .then(function(json) {
          var product = json.product || json;
          if (!product || !product.variants) throw new Error('No product in response');

          /* Filter out disabled variants only (keep sold-out to show as disabled) */
          product.variants = product.variants.filter(function(v) {
            if (disabledVariantIds.length > 0 && disabledVariantIds.indexOf(v.id) !== -1) return false;
            return true;
          });

          self.data = product;

          /* Product image */
          var imgSrc = '';
          if (product.featured_image) {
            imgSrc = (typeof product.featured_image === 'string' ? product.featured_image : (product.featured_image.src || '')).replace(/(\.[^.]+)$/, '_120x$1');
          } else if (product.image && product.image.src) {
            imgSrc = product.image.src.replace(/(\.[^.]+)$/, '_120x$1');
          } else if (product.images && product.images.length > 0) {
            imgSrc = (typeof product.images[0] === 'string' ? product.images[0] : (product.images[0].src || '')).replace(/(\.[^.]+)$/, '_120x$1');
          }
          document.getElementById('cart-size-picker-img').src = imgSrc;
          document.getElementById('cart-size-picker-title').textContent = product.title;

          /* Price: .js returns cents (integer), .json returns string */
          var firstAvailable = product.variants.find(function(v) { return v.available; }) || product.variants[0];
          var rawPrice = firstAvailable.price;
          var priceVal = (typeof rawPrice === 'number' && rawPrice > 1000) ? rawPrice / 100 : parseFloat(rawPrice);
          document.getElementById('cart-size-picker-price').textContent = priceVal.toLocaleString('nl-NL', {minimumFractionDigits: 2, maximumFractionDigits: 2});

          loading.style.display = 'none';

          var optionNames = product.options.map(function(o) {
            return typeof o === 'string' ? o : o.name;
          });

          /* Check if any variant is available at all */
          var availableVariants = product.variants.filter(function(v) { return v.available; });

          /* If only default variant and it's available, just add directly */
          if (availableVariants.length === 1 && optionNames.length === 1 && optionNames[0] === 'Title') {
            self.selectedVariantId = availableVariants[0].id;
            self.addToCart();
            return;
          }

          /* If no available variants remain, show message */
          if (availableVariants.length === 0) {
            optionsContainer.innerHTML = '<p style="padding:12px 0;color:#999;">Sold out</p>';
            return;
          }

          /* Build option groups */
          optionNames.forEach(function(optName, optIndex) {
            var group = document.createElement('div');
            group.className = 'cart-size-picker__option-group';

            var label = document.createElement('p');
            label.className = 'cart-size-picker__option-label';
            label.textContent = optName;
            group.appendChild(label);

            var isColor = self.isColorOption(optName);
            var buttons = document.createElement('div');
            buttons.className = 'cart-size-picker__option-buttons';

            /* Collect ALL option values (including sold-out) */
            var values = [];
            product.variants.forEach(function(v) {
              var val = v['option' + (optIndex + 1)];
              if (val && values.indexOf(val) === -1) {
                values.push(val);
              }
            });

            values.forEach(function(val) {
              var btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'cart-size-picker__option-btn';
              btn.setAttribute('data-option-index', optIndex);
              btn.setAttribute('data-option-value', val);

              /* Check if any available variant has this option value */
              var hasAvailable = availableVariants.some(function(v) {
                return v['option' + (optIndex + 1)] === val;
              });
              if (!hasAvailable) {
                btn.classList.add('cart-size-picker__option-btn--sold-out');
                btn.disabled = true;
              }

              if (isColor) {
                var variantImg = self.getVariantImage(product, optIndex, val);
                if (variantImg) {
                  btn.classList.add('cart-size-picker__option-btn--image');
                  var img = document.createElement('img');
                  img.src = variantImg;
                  img.alt = val;
                  img.width = 40;
                  img.height = 40;
                  btn.appendChild(img);
                  var span = document.createElement('span');
                  span.textContent = val;
                  btn.appendChild(span);
                } else {
                  btn.textContent = val;
                }
              } else {
                btn.textContent = val;
              }

              btn.addEventListener('click', function() {
                buttons.querySelectorAll('.cart-size-picker__option-btn').forEach(function(b) {
                  b.classList.remove('active');
                });
                btn.classList.add('active');
                self.selectedOptions[optIndex] = val;
                self.matchVariant();

                if (isColor) {
                  var varImg = self.getVariantImage(product, optIndex, val);
                  if (varImg) {
                    document.getElementById('cart-size-picker-img').src = varImg.replace('_80x', '_120x');
                  }
                }
              });
              buttons.appendChild(btn);
            });

            group.appendChild(buttons);
            optionsContainer.appendChild(group);
          });

          /* Auto-select if only one value per option */
          optionNames.forEach(function(optName, optIndex) {
            var btns = optionsContainer.querySelectorAll('[data-option-index="' + optIndex + '"]');
            if (btns.length === 1) {
              btns[0].click();
            }
          });
        })
        .catch(function(err) {
          console.error('Size picker error:', err);
          loading.style.display = 'none';
          setTimeout(function() { self.close(); }, 500);
        });
    },

    matchVariant: function() {
      var self = this;
      var product = self.data;
      if (!product) return;

      var confirmBtn = document.getElementById('cart-size-picker-confirm');
      var optionNames = product.options.map(function(o) {
        return typeof o === 'string' ? o : o.name;
      });

      var allSelected = optionNames.every(function(opt, i) {
        return self.selectedOptions[i] !== undefined;
      });

      if (!allSelected) {
        self.selectedVariantId = null;
        confirmBtn.disabled = true;
        return;
      }

      var match = product.variants.find(function(v) {
        return optionNames.every(function(opt, i) {
          return self.selectedOptions[i] === v['option' + (i + 1)];
        });
      });

      if (match) {
        self.selectedVariantId = match.id;
        confirmBtn.disabled = false;

        var rawPrice = match.price;
        var priceVal = (typeof rawPrice === 'number' && rawPrice > 1000) ? rawPrice / 100 : parseFloat(rawPrice);
        document.getElementById('cart-size-picker-price').textContent = priceVal.toLocaleString('nl-NL', {minimumFractionDigits: 2, maximumFractionDigits: 2});
      } else {
        self.selectedVariantId = null;
        confirmBtn.disabled = true;
      }
    },

    /* ================================================================
       ADD TO CART — direct fetch to /cart/add.js replicating the
       exact same logic as product-form.js onSubmitHandler.
       No hidden form needed — works on any page context.
       ================================================================ */
    addToCart: function() {
      var self = this;
      if (!self.selectedVariantId) return;

      var confirmBtn = document.getElementById('cart-size-picker-confirm');
      var loading = document.getElementById('cart-size-picker-loading');
      confirmBtn.disabled = true;
      loading.style.display = 'flex';

      /* Save variant ID before close() resets it */
      var variantId = self.selectedVariantId;

      /* Close the picker UI */
      self.close();

      /* Get the cart drawer element (same lookup as product-form.js) */
      var cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');

      /* Build FormData exactly like product-form.js */
      var formData = new FormData();
      formData.append('id', variantId);
      formData.append('quantity', 1);

      if (cart) {
        formData.append('sections', cart.getSectionsToRender().map(function(s) { return s.id; }));
        formData.append('sections_url', window.location.pathname);
        cart.setActiveElement(document.activeElement);
      }

      fetch(routes.cart_add_url, {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/javascript'
        },
        body: formData
      })
        .then(function(r) { return r.json(); })
        .then(function(response) {
          if (response.status) {
            /* Error — item couldn't be added (sold out, etc.) */
            console.error('Cross-sell add to cart error:', response.description);
            return;
          }
          if (!cart) {
            window.location = window.routes.cart_url;
            return;
          }
          /* Re-render the cart drawer with updated sections (same as product-form.js) */
          cart.renderContents(response);
        })
        .catch(function(e) {
          console.error('Cross-sell add to cart fetch error:', e);
        })
        .finally(function() {
          if (cart && cart.classList.contains('is-empty')) {
            cart.classList.remove('is-empty');
          }
          if (typeof fetch_upsells === 'function') {
            fetch_upsells();
          }
        });
    },

    close: function() {
      document.getElementById('cart-size-picker').style.display = 'none';
      document.getElementById('cart-size-picker-loading').style.display = 'none';
      this.data = null;
      this.selectedVariantId = null;
      this.selectedOptions = {};
    }
  };
</script>
