        "faq_9RzfCj": {
          "type": "faq",
          "settings": {
            "question": "What if I am between sizes of the cycling the baselayer?",
            "answer": "<p>Our baselayers are available in XS, S, M, L, XL and XXL. If you're between sizes, we recommend sizing up for a more comfortable fit.</p>",
            "metafield_key": "",
            "metafield_fallback": ""
          }
        },
        "faq_7idmHH": {
          "type": "faq",
          "settings": {
            "question": "What material are Sockeloen baselayer made of?",
            "answer": "<p>Our baselayers are made of a lightweight fabric that efficiently wicks away moisture and quickly releases heat, keeping your body dry and maintaining a stable core temperature, even during high-intensity efforts.</p>",
            "metafield_key": "custom.materials",
            "metafield_fallback": "Q-Skin"
          }
        },
        "faq_YhiEwH": {
          "type": "faq",
          "settings": {
            "question": "How should I wash my baselayer?",
            "answer": "<p>Machine wash at 30°C inside out. Avoid fabric softener as it reduces moisture-wicking performance. Do not tumble dry — air dry for best results. This keeps the fibers intact and your socks performing at their best.</p>",
            "metafield_key": "",
            "metafield_fallback": ""
          }
        },
        "faq_NLxUKi": {
          "type": "faq",
          "settings": {
            "question": "How long do Sockeloen baslayers last?",
            "answer": "<p>With proper care, our baselayers typically last 1-2 years of regular use. If you experience any quality issues within 6 months, contact us for our satisfaction guarantee.</p>",
            "metafield_key": "",
            "metafield_fallback": ""
          }
        },
        "faq_wRWWf3": {
          "type": "faq",
          "settings": {
