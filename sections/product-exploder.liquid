{{ 'section-product-exploder.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-exploder--{{ section.id }} {
    --exploder-accent: {{ section.settings.accent_color }};
  }
{%- endstyle -%}

{%- liquid
  assign exploder_img = section.settings.image
  if exploder_img == blank
    assign title_lower = product.title | downcase
    if title_lower contains 'pack' and product.images.size >= 4
      assign exploder_img = product.images[3]
    else
      assign exploder_img = product.featured_image
    endif
  endif
-%}

<section
  class="product-exploder product-exploder--{{ section.id }} section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  style="{% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background-color: {{ section.settings.background_color }};{% endif %} color: {{ section.settings.text_color }};"
>
  {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
    <div class="product-exploder__header">
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2 class="product-exploder__heading">
          {{- section.settings.heading -}}
          {%- if section.settings.heading_italic != blank %} <em>{{ section.settings.heading_italic }}</em>{%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <div class="product-exploder__subtitle rte">{{ section.settings.subtitle }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="product-exploder__grid">
    <div class="product-exploder__image-col">
      <div class="product-exploder__image-wrap">
        <div class="product-exploder__image-inner">
          {%- if exploder_img != blank -%}
            <img
              class="product-exploder__image"
              src="{{ exploder_img | image_url: width: 1200 }}"
              srcset="
                {{ exploder_img | image_url: width: 500 }} 500w,
                {{ exploder_img | image_url: width: 750 }} 750w,
                {{ exploder_img | image_url: width: 1000 }} 1000w,
                {{ exploder_img | image_url: width: 1200 }} 1200w
              "
              sizes="(min-width: 750px) 55vw, 100vw"
              alt="{{ exploder_img.alt | escape }}"
              width="{{ exploder_img.width }}"
              height="{{ exploder_img.height }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product-exploder__image' }}
          {%- endif -%}

          {%- for block in section.blocks -%}
            <button
              type="button"
              class="product-exploder__hotspot"
              data-index="{{ forloop.index0 }}"
              style="left: {{ block.settings.hotspot_x }}%; top: {{ block.settings.hotspot_y }}%;"
              aria-label="{{ block.settings.heading | escape | default: 'Hotspot' }}"
              aria-pressed="false"
              {{ block.shopify_attributes }}
            >{{ forloop.index | prepend: '00' | slice: -2, 2 }}</button>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="product-exploder__accordion-col">
      {%- for block in section.blocks -%}
        <div class="product-exploder__item" data-index="{{ forloop.index0 }}">
          <button
            type="button"
            class="product-exploder__item-trigger"
            aria-expanded="false"
          >
            <span class="product-exploder__item-number">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
            <h3 class="product-exploder__item-heading">{{ block.settings.heading | default: 'Hotspot' }}</h3>
            <span class="product-exploder__item-toggle" aria-hidden="true">+</span>
          </button>
          <div class="product-exploder__item-content">
            {%- if block.settings.description != blank -%}
              {%- liquid
                assign desc_output = block.settings.description
                if block.settings.metafield_key != blank
                  assign mf_parts = block.settings.metafield_key | split: '.'
                  if mf_parts.size == 2
                    assign mf_ns = mf_parts[0]
                    assign mf_k = mf_parts[1]
                    assign mf_val = product.metafields[mf_ns][mf_k].value | default: product.metafields[mf_ns][mf_k]
                    if mf_val != blank
                      assign desc_output = desc_output | replace: '[metafield]', mf_val
                    else
                      assign desc_output = desc_output | replace: '[metafield]', ''
                    endif
                  endif
                endif
              -%}
              <div class="rte-inner">{{ desc_output }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('.product-exploder--{{ section.id }}');
    if (!section) return;

    var hotspots = section.querySelectorAll('.product-exploder__hotspot');
    var items = section.querySelectorAll('.product-exploder__item');
    var triggers = section.querySelectorAll('.product-exploder__item-trigger');
    var imageCol = section.querySelector('.product-exploder__image-col');
    var accordionCol = section.querySelector('.product-exploder__accordion-col');
    var currentIndex = -1;

    function activate(index) {
      if (index === currentIndex) {
        /* Clicking the active item deactivates it */
        deactivateAll();
        currentIndex = -1;
        return;
      }

      deactivateAll();
      currentIndex = index;

      var hotspot = section.querySelector('.product-exploder__hotspot[data-index="' + index + '"]');
      var item = section.querySelector('.product-exploder__item[data-index="' + index + '"]');

      if (hotspot) {
        hotspot.classList.add('is-active');
        hotspot.setAttribute('aria-pressed', 'true');
      }

      if (item) {
        item.classList.add('is-active');
        var trigger = item.querySelector('.product-exploder__item-trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'true');

        /* On mobile, scroll accordion item into view when hotspot is clicked */
        if (window.innerWidth < 750) {
          item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
    }

    function deactivateAll() {
      hotspots.forEach(function (h) {
        h.classList.remove('is-active');
        h.setAttribute('aria-pressed', 'false');
      });
      items.forEach(function (i) {
        i.classList.remove('is-active');
        var trigger = i.querySelector('.product-exploder__item-trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      });
    }

    /* Hotspot click */
    hotspots.forEach(function (hotspot) {
      hotspot.addEventListener('click', function () {
        var idx = parseInt(this.getAttribute('data-index'), 10);
        activate(idx);
      });
    });

    /* Accordion trigger click */
    triggers.forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var item = this.closest('.product-exploder__item');
        if (!item) return;
        var idx = parseInt(item.getAttribute('data-index'), 10);
        activate(idx);
      });
    });

    /* Keyboard support for hotspots */
    hotspots.forEach(function (hotspot) {
      hotspot.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    });

    /* Default: activate first item */
    if (hotspots.length > 0) {
      activate(0);
    }

    /* Scroll reveal with IntersectionObserver */
    if ('IntersectionObserver' in window) {
      var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        if (imageCol) imageCol.classList.add('is-visible');
        if (accordionCol) accordionCol.classList.add('is-visible');
      } else {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.15,
            rootMargin: '0px 0px -50px 0px'
          }
        );

        if (imageCol) observer.observe(imageCol);
        if (accordionCol) observer.observe(accordionCol);
      }
    } else {
      /* Fallback: show immediately */
      if (imageCol) imageCol.classList.add('is-visible');
      if (accordionCol) accordionCol.classList.add('is-visible');
    }
  })();
</script>

{% schema %}
{
  "name": "Product Exploder",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let's take a look"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic accent)",
      "default": "inside the sock"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image (uses first product image if empty)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F76503"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "header",
          "content": "Position"
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "label": "Horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "label": "Vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "header",
          "content": "Dynamic metafield"
        },
        {
          "type": "select",
          "id": "metafield_key",
          "label": "Insert metafield value",
          "info": "Use [metafield] in the description as placeholder. It will be replaced with the selected metafield value.",
          "options": [
            { "value": "", "label": "— None —" },
            { "value": "custom.height", "label": "Height (custom.height)" },
            { "value": "custom.custom_benefit_1", "label": "Benefit 1 (custom.custom_benefit_1)" },
            { "value": "custom.custom_benefit_2", "label": "Benefit 2 (custom.custom_benefit_2)" },
            { "value": "custom.custom_benefit_3", "label": "Benefit 3 (custom.custom_benefit_3)" },
            { "value": "descriptors.subtitle", "label": "Subtitle (descriptors.subtitle)" }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Exploder",
      "blocks": [
        { "type": "hotspot" },
        { "type": "hotspot" },
        { "type": "hotspot" },
        { "type": "hotspot" }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
