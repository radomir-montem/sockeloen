{{ 'section-product-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-faq--{{ section.id }} {
    --faq-accent: {{ section.settings.accent_color }};
  }
{%- endstyle -%}

{%- assign faq_img = section.settings.image | default: product.images[4] | default: product.featured_image -%}

<section
  class="product-faq product-faq--{{ section.id }} section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  style="{% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background-color: {{ section.settings.background_color }};{% endif %} color: {{ section.settings.text_color }};"
>
  <div class="product-faq__grid">
    <div class="product-faq__content-col">
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2 class="product-faq__heading">
          {{- section.settings.heading -}}
          {%- if section.settings.heading_italic != blank %}
            <em>{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </h2>
      {%- endif -%}

      <div class="product-faq__accordion">
        {%- for block in section.blocks -%}
          <div class="product-faq__item{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="product-faq__trigger"
              aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <h3 class="product-faq__question">{{ block.settings.question }}</h3>
              <span class="product-faq__toggle" aria-hidden="true">+</span>
            </button>
            <div class="product-faq__answer">
              {%- if block.settings.answer != blank -%}
                {%- liquid
                  assign faq_desc_output = block.settings.answer
                  assign faq_mf_obj = nil
                  if block.settings.metafield_key != blank
                    assign faq_mf_parts = block.settings.metafield_key | split: '.'
                    if faq_mf_parts.size == 2
                      assign faq_mf_ns = faq_mf_parts[0]
                      assign faq_mf_k = faq_mf_parts[1]
                      assign faq_mf_obj = product.metafields[faq_mf_ns][faq_mf_k]
                    endif
                  endif
                -%}
                {%- if faq_mf_obj != blank -%}
                  {%- capture faq_mf_val -%}{{ faq_mf_obj | metafield_tag | strip_html }}{%- endcapture -%}
                {%- endif -%}
                {%- liquid
                  assign faq_mf_val = faq_mf_val | strip
                  if faq_mf_obj != blank and faq_mf_val != blank
                    assign faq_desc_output = faq_desc_output | replace: '[metafield]', faq_mf_val
                  elsif block.settings.metafield_fallback != blank
                    assign faq_desc_output = faq_desc_output | replace: '[metafield]', block.settings.metafield_fallback
                  else
                    assign faq_desc_output = faq_desc_output | replace: '[metafield]', ''
                  endif
                -%}
                <div class="rte-inner">{{ faq_desc_output }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="product-faq__image-col">
      {%- if faq_img != blank -%}
        <img
          class="product-faq__image"
          src="{{ faq_img | image_url: width: 1000 }}"
          srcset="
            {{ faq_img | image_url: width: 400 }} 400w,
            {{ faq_img | image_url: width: 600 }} 600w,
            {{ faq_img | image_url: width: 800 }} 800w,
            {{ faq_img | image_url: width: 1000 }} 1000w
          "
          sizes="(min-width: 750px) 45vw, 100vw"
          alt="{{ faq_img.alt | escape }}"
          width="{{ faq_img.width }}"
          height="{{ faq_img.height }}"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-faq__image' }}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('.product-faq--{{ section.id }}');
    if (!section) return;

    var items = section.querySelectorAll('.product-faq__item');
    var triggers = section.querySelectorAll('.product-faq__trigger');
    var contentCol = section.querySelector('.product-faq__content-col');
    var imageCol = section.querySelector('.product-faq__image-col');

    function activate(index) {
      var clickedItem = section.querySelector('.product-faq__item[data-index="' + index + '"]');
      var isAlreadyActive = clickedItem && clickedItem.classList.contains('is-active');

      /* Close all items */
      items.forEach(function (item) {
        item.classList.remove('is-active');
        var trigger = item.querySelector('.product-faq__trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      });

      /* If clicking active item, just close it */
      if (isAlreadyActive) return;

      /* Open clicked item */
      if (clickedItem) {
        clickedItem.classList.add('is-active');
        var trigger = clickedItem.querySelector('.product-faq__trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'true');
      }
    }

    /* Accordion trigger click */
    triggers.forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var item = this.closest('.product-faq__item');
        if (!item) return;
        var idx = parseInt(item.getAttribute('data-index'), 10);
        activate(idx);
      });
    });

    /* Scroll reveal with IntersectionObserver */
    if ('IntersectionObserver' in window) {
      var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        if (contentCol) contentCol.classList.add('is-visible');
        if (imageCol) imageCol.classList.add('is-visible');
      } else {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.15,
            rootMargin: '0px 0px -50px 0px'
          }
        );

        if (contentCol) observer.observe(contentCol);
        if (imageCol) observer.observe(imageCol);
      }
    } else {
      /* Fallback: show immediately */
      if (contentCol) contentCol.classList.add('is-visible');
      if (imageCol) imageCol.classList.add('is-visible');
    }
  })();
</script>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic accent)",
      "default": "questions"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (uses 5th product image if empty)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F76503"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        },
        {
          "type": "header",
          "content": "Dynamic metafield"
        },
        {
          "type": "select",
          "id": "metafield_key",
          "label": "Insert metafield value",
          "info": "Use [metafield] in the answer as placeholder. It will be replaced with the selected metafield value.",
          "options": [
            { "value": "", "label": "— None —" },
            { "value": "custom.height", "label": "Height" },
            { "value": "custom.knit_structure", "label": "Knit Structure" },
            { "value": "custom.materials", "label": "Materials" },
            { "value": "custom.benefit_1", "label": "Benefit 1" },
            { "value": "custom.benefit_2", "label": "Benefit 2" },
            { "value": "custom.benefit_3", "label": "Benefit 3" },
            { "value": "custom.badge", "label": "Badge" },
            { "value": "descriptors.subtitle", "label": "Subtitle" }
          ],
          "default": ""
        },
        {
          "type": "text",
          "id": "metafield_fallback",
          "label": "Fallback text",
          "info": "Shown in place of [metafield] when the product has no value for the selected metafield."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What size cycling socks should I choose?",
            "answer": "<p>Our socks come in S/M (36-41) and L/XL (42-47). If you're between sizes, we recommend sizing up for a more comfortable fit. Check our size guide on each product page for detailed measurements.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What material are Sockeloen socks made of?",
            "answer": "<p>Our cycling socks are made from a premium blend of recycled polyamide, polypropylene, and elastane. This combination provides excellent moisture-wicking, durability, and a perfect fit that stays in place during long rides.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How should I wash my cycling socks?",
            "answer": "<p>Machine wash at 30°C inside out. Avoid fabric softener as it reduces moisture-wicking performance. Do not tumble dry — air dry for best results. This keeps the fibers intact and your socks performing at their best.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long do Sockeloen socks last?",
            "answer": "<p>With proper care, our socks typically last 1-2 years of regular use. The reinforced heel and toe areas are designed for extra durability. If you experience any quality issues within 6 months, contact us for our satisfaction guarantee.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do you offer free shipping?",
            "answer": "<p>Yes! We offer free shipping on all orders over €50 within Europe. Orders are typically dispatched within 1-2 business days and delivered within 2-5 working days depending on your location.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy on unworn items in original packaging. If you're not satisfied, simply reach out to us and we'll arrange a hassle-free return. Your satisfaction is our priority.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why are cycling socks longer than regular socks?",
            "answer": "<p>The taller cuff provides aerodynamic benefits by creating a smoother airflow over the leg. It also offers sun protection and prevents chafing from shoe edges. Most pro cyclists prefer a cuff height of 15-20cm.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I use these socks for other sports?",
            "answer": "<p>Absolutely! While designed for cycling, our socks perform great for running, hiking, and everyday wear. The moisture-wicking properties and comfortable fit make them versatile for any activity.</p>"
          }
        }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
