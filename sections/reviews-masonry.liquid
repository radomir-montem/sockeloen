{{ 'section-reviews-masonry.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .reviews-masonry {
    --reviews-accent: {{ section.settings.accent_color }};
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .reviews-masonry {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="reviews-masonry"
  id="reviews-masonry-{{ section.id }}"
  aria-label="Customer reviews"
>
  <div class="reviews-masonry__inner">
    <div class="reviews-masonry__grid">

      {%- comment -%} Left sidebar {%- endcomment -%}
      <div class="reviews-masonry__sidebar" data-reviews-sidebar>
        {%- comment -%} Reviews.io badge ribbon — updated live by JS {%- endcomment -%}
        <a class="reviews-masonry__ribbon" href="https://www.reviews.io/company-reviews/store/sockeloen-nl" target="_blank" rel="noopener noreferrer" aria-label="Review rating">
          <div class="reviews-masonry__ribbon-rating">
            <div class="reviews-masonry__ribbon-stars" role="img" aria-label="4.5 out of 5 stars" data-reviews-badge-stars></div>
            <span class="reviews-masonry__ribbon-text" data-reviews-badge-count>Read our <strong data-reviews-badge-total>5,065</strong> reviews</span>
          </div>
        </a>

        <h2 class="reviews-masonry__heading">
          {{ section.settings.heading }}
          {%- if section.settings.heading_italic != blank -%}
            <br><em>{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </h2>

        {%- if section.settings.subtitle != blank -%}
          <p class="reviews-masonry__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <a class="reviews-masonry__powered" href="https://www.reviews.io/company-reviews/store/sockeloen-nl" target="_blank" rel="noopener noreferrer">
          <span>Verified by</span>
          <img src="https://assets.reviews.io/img/all-global-assets/logo/reviewsio-logo.svg" alt="REVIEWS.io" class="reviews-masonry__reviewsio-logo" width="90" height="20" loading="lazy">
        </a>
      </div>

      {%- comment -%} Right cards area — populated by JS from Reviews.io API {%- endcomment -%}
      {%- comment -%} Mobile: horizontal carousel / Desktop: masonry grid {%- endcomment -%}
      <div class="reviews-masonry__cards" role="list" data-reviews-cards>
        <div class="reviews-masonry__carousel-track" data-reviews-track>
        {%- comment -%} Fallback: theme editor blocks shown until JS loads {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <article
              class="reviews-masonry__card"
              role="listitem"
              data-reviews-card
              data-fallback
              {{ block.shopify_attributes }}
            >
              <span class="reviews-masonry__quote" aria-hidden="true">&ldquo;</span>

              {%- assign rating = block.settings.rating | default: 5 -%}
              <div class="reviews-masonry__stars" role="img" aria-label="{{ rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  <span class="reviews-masonry__star" style="background:{% if i <= rating %}#00b67a{% else %}#dcdce6{% endif %};" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>
                    </svg>
                  </span>
                {%- endfor -%}
              </div>

              {%- if block.settings.title != blank -%}
                <h3 class="reviews-masonry__card-title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.body != blank -%}
                <p class="reviews-masonry__card-body">{{ block.settings.body }}</p>
              {%- endif -%}

              <div class="reviews-masonry__card-footer">
                {%- if block.settings.author != blank -%}
                  <span class="reviews-masonry__card-author">{{ block.settings.author }}</span>
                {%- endif -%}
                {%- if block.settings.date != blank -%}
                  <span class="reviews-masonry__card-date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
        </div>{%- comment -%} /.reviews-masonry__carousel-track {%- endcomment -%}

        {%- comment -%} Carousel nav dots — mobile only, populated by JS {%- endcomment -%}
        <div class="reviews-masonry__carousel-nav" data-reviews-nav aria-label="Review navigation"></div>
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    var STORE_ID = 'sockeloen-nl';
    var REVIEWS_URL = 'https://www.reviews.io/company-reviews/store/' + STORE_ID;
    var MAX_REVIEWS = 6;
    var MIN_RATING = {{ section.settings.min_rating | default: 4 }};
    var section = document.getElementById('reviews-masonry-{{ section.id }}');
    if (!section) return;

    var cardsContainer = section.querySelector('[data-reviews-cards]');
    var trackContainer = section.querySelector('[data-reviews-track]');
    var navContainer = section.querySelector('[data-reviews-nav]');
    var badgeCount = section.querySelector('[data-reviews-badge-count]');
    var badgeStars = section.querySelector('[data-reviews-badge-stars]');

    /* Build star SVGs — matching Reviews.io green badge style */
    function starSVG(filled) {
      var bg = filled ? '#00b67a' : '#dcdce6';
      return '<span class="reviews-masonry__star" style="background:' + bg + ';" aria-hidden="true">'
        + '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">'
        + '<path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>'
        + '</svg></span>';
    }

    function badgeStarSVG(filled) {
      var color = filled ? '#F47621' : '#dcdce6';
      return '<svg class="reviews-masonry__ribbon-star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">'
        + '<path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="' + color + '"/>'
        + '</svg>';
    }

    function renderStars(rating) {
      var html = '';
      for (var i = 1; i <= 5; i++) {
        html += starSVG(i <= Math.round(rating));
      }
      return html;
    }

    function renderBadgeStars(rating) {
      var html = '';
      var rounded = Math.round(rating);
      for (var i = 1; i <= 5; i++) {
        html += badgeStarSVG(i <= rounded);
      }
      return html;
    }

    function timeAgo(dateStr) {
      var d = new Date(dateStr);
      if (isNaN(d.getTime())) return dateStr;
      var now = new Date();
      var diff = Math.floor((now - d) / 1000);
      if (diff < 86400) return 'Today';
      var days = Math.floor(diff / 86400);
      if (days === 1) return '1 day ago';
      if (days < 7) return days + ' days ago';
      var weeks = Math.floor(days / 7);
      if (weeks === 1) return '1 week ago';
      if (weeks < 5) return weeks + ' weeks ago';
      var months = Math.floor(days / 30);
      if (months === 1) return '1 month ago';
      if (months < 12) return months + ' months ago';
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    function buildCard(review) {
      var rating = review.rating || 5;
      var title = review.title || '';
      var body = review.comments || review.review || '';
      var author = review.reviewer ? review.reviewer.first_name || '' : '';
      if (review.reviewer && review.reviewer.last_name && review.reviewer.last_name.trim()) {
        author += ' ' + review.reviewer.last_name.charAt(0) + '.';
      }
      var date = review.date_created || review.timeago || '';
      var images = review.images || [];

      var html = '<a href="' + REVIEWS_URL + '" target="_blank" rel="noopener noreferrer" class="reviews-masonry__card reviews-masonry__card--link" role="listitem" data-reviews-card>';
      html += '<span class="reviews-masonry__quote" aria-hidden="true">&ldquo;</span>';
      html += '<div class="reviews-masonry__stars" role="img" aria-label="' + rating + ' out of 5 stars">';
      html += renderStars(rating);
      html += '</div>';
      if (title) html += '<h3 class="reviews-masonry__card-title">' + escapeHtml(title) + '</h3>';
      if (body) html += '<p class="reviews-masonry__card-body">' + escapeHtml(body) + '</p>';

      /* Render user-uploaded images */
      if (images.length > 0) {
        html += '<div class="reviews-masonry__card-images">';
        var maxImages = Math.min(images.length, 3);
        for (var img = 0; img < maxImages; img++) {
          if (images[img].image && images[img].status === 'active') {
            html += '<img class="reviews-masonry__card-img" src="' + images[img].image + '" alt="Customer photo" loading="lazy" />';
          }
        }
        html += '</div>';
      }

      html += '<div class="reviews-masonry__card-footer">';
      if (author) html += '<span class="reviews-masonry__card-author">' + escapeHtml(author) + '</span>';
      if (date) html += '<span class="reviews-masonry__card-date">' + timeAgo(date) + '</span>';
      html += '</div></a>';
      return html;
    }

    /* Fetch merchant reviews + product rating stats in parallel */
    var merchantUrl = 'https://api.reviews.io/merchant/reviews?store=' + STORE_ID
      + '&per_page=25'
      + '&min_rating=' + MIN_RATING
      + '&order=newest';
    var productRatingUrl = 'https://api.reviews.io/product/rating?store=' + STORE_ID;

    Promise.all([
      fetch(merchantUrl).then(function (r) { return r.json(); }),
      fetch(productRatingUrl).then(function (r) { return r.json(); }).catch(function () { return null; })
    ])
      .then(function (results) {
        var data = results[0];
        var productData = results[1];

        if (!data || !data.reviews || !data.reviews.length) return;

        /* Combine company + product review counts and compute weighted average */
        if (data.stats) {
          var companyCount = parseInt(data.stats.total_reviews, 10) || 0;
          var companyAvg = parseFloat(data.stats.average_rating) || 0;
          var productCount = (productData && productData.count) ? parseInt(productData.count, 10) : 0;
          var productAvg = (productData && productData.rating) ? parseFloat(productData.rating) : 0;

          var totalReviews = companyCount + productCount;
          var combinedAvg = totalReviews > 0
            ? ((companyAvg * companyCount) + (productAvg * productCount)) / totalReviews
            : companyAvg;

          if (badgeStars) {
            badgeStars.innerHTML = renderBadgeStars(combinedAvg);
            badgeStars.setAttribute('aria-label', combinedAvg.toFixed(2) + ' out of 5 stars');
          }

          if (badgeCount) {
            var totalEl = badgeCount.querySelector('[data-reviews-badge-total]');
            if (totalEl) {
              totalEl.textContent = totalReviews.toLocaleString();
            }
          }
        }

        /* Remove fallback blocks */
        var fallbacks = trackContainer.querySelectorAll('[data-fallback]');
        fallbacks.forEach(function (el) { el.remove(); });

        /* Render real reviews — prioritise reviews with images (at least 3) */
        var MIN_WITH_IMAGES = 3;
        var withImages = [];
        var withoutImages = [];
        for (var r = 0; r < data.reviews.length; r++) {
          var review = data.reviews[r];
          var body = review.comments || review.review || '';
          if (!body.trim()) continue;
          var hasActiveImage = false;
          if (review.images && review.images.length > 0) {
            for (var im = 0; im < review.images.length; im++) {
              if (review.images[im].image && review.images[im].status === 'active') {
                hasActiveImage = true;
                break;
              }
            }
          }
          if (hasActiveImage) {
            withImages.push(review);
          } else {
            withoutImages.push(review);
          }
        }
        /* Build final list: take up to MIN_WITH_IMAGES from image reviews first,
           then fill remaining slots, then top up with more image reviews if available */
        var selected = [];
        var imgCount = Math.min(withImages.length, MIN_WITH_IMAGES);
        for (var i = 0; i < imgCount; i++) selected.push(withImages[i]);
        var remaining = MAX_REVIEWS - selected.length;
        var noImgCount = Math.min(withoutImages.length, remaining);
        for (var j = 0; j < noImgCount; j++) selected.push(withoutImages[j]);
        remaining = MAX_REVIEWS - selected.length;
        for (var k = imgCount; k < withImages.length && remaining > 0; k++) {
          selected.push(withImages[k]);
          remaining--;
        }

        /* Interleave: spread image reviews evenly across positions */
        var finalWithImg = [];
        var finalWithoutImg = [];
        for (var s = 0; s < selected.length; s++) {
          var hasImg = false;
          if (selected[s].images && selected[s].images.length > 0) {
            for (var chk = 0; chk < selected[s].images.length; chk++) {
              if (selected[s].images[chk].image && selected[s].images[chk].status === 'active') { hasImg = true; break; }
            }
          }
          if (hasImg) finalWithImg.push(selected[s]);
          else finalWithoutImg.push(selected[s]);
        }
        var interleaved = [];
        var imgIdx = 0, noImgIdx = 0;
        for (var slot = 0; slot < selected.length; slot++) {
          /* Place image reviews at positions 0, 2, 4 (every other) */
          if (slot % 2 === 0 && imgIdx < finalWithImg.length) {
            interleaved.push(finalWithImg[imgIdx++]);
          } else if (noImgIdx < finalWithoutImg.length) {
            interleaved.push(finalWithoutImg[noImgIdx++]);
          } else if (imgIdx < finalWithImg.length) {
            interleaved.push(finalWithImg[imgIdx++]);
          } else if (noImgIdx < finalWithoutImg.length) {
            interleaved.push(finalWithoutImg[noImgIdx++]);
          }
        }

        var html = '';
        for (var c = 0; c < interleaved.length; c++) {
          html += buildCard(interleaved[c]);
        }
        trackContainer.insertAdjacentHTML('beforeend', html);

        /* Init carousel for mobile */
        initCarousel();

        /* Re-run animations on new cards */
        initAnimations();
      })
      .catch(function (err) {
        console.warn('Reviews.io fetch failed, showing fallback blocks', err);
        initAnimations();
      });

    function initCarousel() {
      if (!trackContainer || !navContainer) return;
      var cards = trackContainer.querySelectorAll('[data-reviews-card]');
      if (cards.length < 2) return;

      /* Build nav dots */
      var dotsHtml = '';
      for (var d = 0; d < cards.length; d++) {
        dotsHtml += '<button class="reviews-masonry__dot' + (d === 0 ? ' is-active' : '') + '" data-slide="' + d + '" aria-label="Go to review ' + (d + 1) + '"></button>';
      }
      navContainer.innerHTML = dotsHtml;

      var dots = navContainer.querySelectorAll('.reviews-masonry__dot');
      var currentIndex = 0;

      function goToSlide(index) {
        currentIndex = index;
        cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        dots.forEach(function (dot, i) {
          dot.classList.toggle('is-active', i === index);
        });
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          goToSlide(parseInt(this.getAttribute('data-slide'), 10));
        });
      });

      /* Detect current slide on scroll (snap-based) */
      var scrollTimeout;
      cardsContainer.addEventListener('scroll', function () {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(function () {
          var scrollLeft = cardsContainer.scrollLeft;
          var cardWidth = cards[0].offsetWidth;
          var gap = 16;
          var newIndex = Math.round(scrollLeft / (cardWidth + gap));
          newIndex = Math.max(0, Math.min(newIndex, cards.length - 1));
          if (newIndex !== currentIndex) {
            currentIndex = newIndex;
            dots.forEach(function (dot, i) {
              dot.classList.toggle('is-active', i === currentIndex);
            });
          }
        }, 50);
      });
    }

    function initAnimations() {
      var sidebar = section.querySelector('[data-reviews-sidebar]');
      var cards = section.querySelectorAll('[data-reviews-card]');

      if (!('IntersectionObserver' in window)) {
        if (sidebar) sidebar.classList.add('is-visible');
        cards.forEach(function (card) { card.classList.add('is-visible'); });
        return;
      }

      /* Sidebar slide-in */
      if (sidebar && !sidebar.classList.contains('is-visible')) {
        var sidebarObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                sidebarObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        sidebarObserver.observe(sidebar);
      }

      /* Cards staggered fade-up */
      var cardObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var card = entry.target;
              var index = parseInt(card.getAttribute('data-card-index'), 10) || 0;
              card.style.transitionDelay = (index % 3) * 100 + 'ms';
              card.classList.add('is-visible');
              cardObserver.unobserve(card);
            }
          });
        },
        { threshold: 0.08 }
      );

      cards.forEach(function (card, i) {
        card.setAttribute('data-card-index', i);
        cardObserver.observe(card);
      });
    }

    /* Init animations for fallback blocks immediately (in case API is slow) */
    initAnimations();
  })();
</script>

{% schema %}
{
  "name": "Reviews Masonry",
  "tag": "section",
  "class": "section-reviews-masonry",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic accent)",
      "default": "riders say?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real feedback from cyclists who ride in Sockeloen socks every day."
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Badge text (fallback)",
      "default": "4.53/5 based on 5,065 reviews",
      "info": "Shown until live data loads from Reviews.io"
    },
    {
      "type": "header",
      "content": "Reviews.io Settings"
    },
    {
      "type": "range",
      "id": "min_rating",
      "label": "Minimum star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F76503"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review (fallback)",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Amazing quality"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "These socks are incredible. Perfect cushioning and they stay up the entire ride."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Mark T."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2 days ago"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Masonry",
      "settings": {
        "review_count": "4.51/5 based on 2,376 reviews"
      }
    }
  ]
}
{% endschema %}
