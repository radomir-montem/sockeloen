{{ 'section-reviews-masonry.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .reviews-masonry {
    --reviews-accent: {{ section.settings.accent_color }};
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .reviews-masonry {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- capture star_filled -%}
<span class="reviews-masonry__star" style="background:#00b67a;" aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>
  </svg>
</span>
{%- endcapture -%}

{%- capture star_empty -%}
<span class="reviews-masonry__star" style="background:#dcdce6;" aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>
  </svg>
</span>
{%- endcapture -%}

{%- capture badge_star_filled -%}
<span class="reviews-masonry__badge-star" style="background:#00b67a;" aria-hidden="true">
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>
  </svg>
</span>
{%- endcapture -%}

<section
  class="reviews-masonry"
  id="reviews-masonry-{{ section.id }}"
  aria-label="Customer reviews"
>
  <div class="reviews-masonry__inner">
    <div class="reviews-masonry__grid">

      {%- comment -%} Left sidebar {%- endcomment -%}
      <div class="reviews-masonry__sidebar" data-reviews-sidebar>
        <div class="reviews-masonry__badge" aria-label="Review rating">
          <div class="reviews-masonry__badge-stars" role="img" aria-label="5 out of 5 stars">
            {{ badge_star_filled }}
            {{ badge_star_filled }}
            {{ badge_star_filled }}
            {{ badge_star_filled }}
            {{ badge_star_filled }}
          </div>
          <span class="reviews-masonry__badge-count" data-reviews-badge-count>{{ section.settings.review_count }}</span>
        </div>

        <h2 class="reviews-masonry__heading">
          {{ section.settings.heading }}
          {%- if section.settings.heading_italic != blank -%}
            <br><em>{{ section.settings.heading_italic }}</em>
          {%- endif -%}
        </h2>

        {%- if section.settings.subtitle != blank -%}
          <p class="reviews-masonry__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Right cards area — populated by JS from Reviews.io API {%- endcomment -%}
      <div class="reviews-masonry__cards" role="list" data-reviews-cards>
        {%- comment -%} Fallback: theme editor blocks shown until JS loads {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <article
              class="reviews-masonry__card"
              role="listitem"
              data-reviews-card
              data-fallback
              {{ block.shopify_attributes }}
            >
              <span class="reviews-masonry__quote" aria-hidden="true">&ldquo;</span>

              {%- assign rating = block.settings.rating | default: 5 -%}
              <div class="reviews-masonry__stars" role="img" aria-label="{{ rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= rating -%}
                    {{ star_filled }}
                  {%- else -%}
                    {{ star_empty }}
                  {%- endif -%}
                {%- endfor -%}
              </div>

              {%- if block.settings.title != blank -%}
                <h3 class="reviews-masonry__card-title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.body != blank -%}
                <p class="reviews-masonry__card-body">{{ block.settings.body }}</p>
              {%- endif -%}

              <div class="reviews-masonry__card-footer">
                {%- if block.settings.author != blank -%}
                  <span class="reviews-masonry__card-author">{{ block.settings.author }}</span>
                {%- endif -%}
                {%- if block.settings.date != blank -%}
                  <span class="reviews-masonry__card-date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    var STORE_ID = 'sockeloen-nl';
    var MAX_REVIEWS = {{ section.settings.max_reviews | default: 20 }};
    var MIN_RATING = {{ section.settings.min_rating | default: 4 }};
    var section = document.getElementById('reviews-masonry-{{ section.id }}');
    if (!section) return;

    var cardsContainer = section.querySelector('[data-reviews-cards]');
    var badgeCount = section.querySelector('[data-reviews-badge-count]');

    /* Build star SVGs */
    function starSVG(filled) {
      var bg = filled ? '#00b67a' : '#dcdce6';
      return '<span class="reviews-masonry__star" style="background:' + bg + ';" aria-hidden="true">'
        + '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">'
        + '<path d="M12 2.5l2.9 5.8 6.4.9-4.6 4.5 1.1 6.4L12 17.3l-5.8 2.8 1.1-6.4L2.7 9.2l6.4-.9L12 2.5z" fill="#fff"/>'
        + '</svg></span>';
    }

    function renderStars(rating) {
      var html = '';
      for (var i = 1; i <= 5; i++) {
        html += starSVG(i <= rating);
      }
      return html;
    }

    function timeAgo(dateStr) {
      var d = new Date(dateStr);
      if (isNaN(d.getTime())) return dateStr;
      var now = new Date();
      var diff = Math.floor((now - d) / 1000);
      if (diff < 86400) return 'Today';
      var days = Math.floor(diff / 86400);
      if (days === 1) return '1 day ago';
      if (days < 7) return days + ' days ago';
      var weeks = Math.floor(days / 7);
      if (weeks === 1) return '1 week ago';
      if (weeks < 5) return weeks + ' weeks ago';
      var months = Math.floor(days / 30);
      if (months === 1) return '1 month ago';
      if (months < 12) return months + ' months ago';
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function buildCard(review) {
      var rating = review.rating || 5;
      var title = review.title || '';
      var body = review.comments || review.review || '';
      var author = review.reviewer ? review.reviewer.first_name || '' : '';
      if (review.reviewer && review.reviewer.last_name) {
        author += ' ' + review.reviewer.last_name.charAt(0) + '.';
      }
      var date = review.date_created || review.timeago || '';

      var html = '<article class="reviews-masonry__card" role="listitem" data-reviews-card>';
      html += '<span class="reviews-masonry__quote" aria-hidden="true">&ldquo;</span>';
      html += '<div class="reviews-masonry__stars" role="img" aria-label="' + rating + ' out of 5 stars">';
      html += renderStars(Math.round(rating));
      html += '</div>';
      if (title) html += '<h3 class="reviews-masonry__card-title">' + escapeHtml(title) + '</h3>';
      if (body) html += '<p class="reviews-masonry__card-body">' + escapeHtml(body) + '</p>';
      html += '<div class="reviews-masonry__card-footer">';
      if (author) html += '<span class="reviews-masonry__card-author">' + escapeHtml(author) + '</span>';
      if (date) html += '<span class="reviews-masonry__card-date">' + timeAgo(date) + '</span>';
      html += '</div></article>';
      return html;
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    /* Fetch from Reviews.io API */
    var url = 'https://api.reviews.io/merchant/reviews?store=' + STORE_ID
      + '&per_page=' + MAX_REVIEWS
      + '&min_rating=' + MIN_RATING
      + '&order=newest';

    fetch(url)
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (!data || !data.reviews || !data.reviews.length) return;

        /* Update badge with real stats */
        if (badgeCount && data.stats) {
          var avg = parseFloat(data.stats.average_rating).toFixed(1);
          var total = parseInt(data.stats.total_reviews, 10);
          var display = total >= 1000 ? Math.floor(total / 100) * 100 + '+' : total + '';
          badgeCount.textContent = avg + '/5 based on ' + display + ' reviews';
        }

        /* Remove fallback blocks */
        var fallbacks = cardsContainer.querySelectorAll('[data-fallback]');
        fallbacks.forEach(function (el) { el.remove(); });

        /* Render real reviews */
        var html = '';
        data.reviews.forEach(function (review) {
          /* Skip reviews with no text */
          var body = review.comments || review.review || '';
          if (!body.trim()) return;
          html += buildCard(review);
        });
        cardsContainer.insertAdjacentHTML('beforeend', html);

        /* Re-run animations on new cards */
        initAnimations();
      })
      .catch(function (err) {
        console.warn('Reviews.io fetch failed, showing fallback blocks', err);
        initAnimations();
      });

    function initAnimations() {
      var sidebar = section.querySelector('[data-reviews-sidebar]');
      var cards = section.querySelectorAll('[data-reviews-card]');

      if (!('IntersectionObserver' in window)) {
        if (sidebar) sidebar.classList.add('is-visible');
        cards.forEach(function (card) { card.classList.add('is-visible'); });
        return;
      }

      /* Sidebar slide-in */
      if (sidebar && !sidebar.classList.contains('is-visible')) {
        var sidebarObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                sidebarObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        sidebarObserver.observe(sidebar);
      }

      /* Cards staggered fade-up */
      var cardObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var card = entry.target;
              var index = parseInt(card.getAttribute('data-card-index'), 10) || 0;
              card.style.transitionDelay = (index % 4) * 100 + 'ms';
              card.classList.add('is-visible');
              cardObserver.unobserve(card);
            }
          });
        },
        { threshold: 0.08 }
      );

      cards.forEach(function (card, i) {
        card.setAttribute('data-card-index', i);
        cardObserver.observe(card);
      });
    }

    /* Init animations for fallback blocks immediately (in case API is slow) */
    initAnimations();
  })();
</script>

{% schema %}
{
  "name": "Reviews Masonry",
  "tag": "section",
  "class": "section-reviews-masonry",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic accent)",
      "default": "riders say?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real feedback from cyclists who ride in Sockeloen socks every day."
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Badge text (fallback)",
      "default": "4.5/5 based on 2300+ reviews",
      "info": "Shown until live data loads from Reviews.io"
    },
    {
      "type": "header",
      "content": "Reviews.io Settings"
    },
    {
      "type": "range",
      "id": "max_reviews",
      "label": "Number of reviews to load",
      "min": 6,
      "max": 30,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "min_rating",
      "label": "Minimum star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F76503"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review (fallback)",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Amazing quality"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "These socks are incredible. Perfect cushioning and they stay up the entire ride."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Mark T."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2 days ago"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Masonry",
      "settings": {
        "review_count": "4.5/5 based on 2300+ reviews"
      }
    }
  ]
}
{% endschema %}
