{% if section.settings.enable_sticky %}
  <style>
    #shopify-section-announcement-bar {
      position: sticky;
      top: 0;
    }

    .shopify-section-header-sticky {
      top: var(--announcemet-bar-height, 38px);
    }

    @media (max-width: 749px) {
      .shopify-section-header-sticky {
        top: var(--announcemet-bar-height, 52px);
      }
    }
  </style>
{% endif %}

{% if section.settings.sale_mode %}
  <style>
    .announcement-bar--sale {
      background-color: #1a1a1a !important;
      position: relative;
      overflow: hidden;
    }

    /* Full-bleed, no centering — the marquee track handles its own layout
       and needs the full bar width to scroll edge-to-edge. */
    .announcement-bar--sale .announcement-bar__link {
      justify-content: flex-start !important;
      padding: 0 !important;
      overflow: hidden !important;
    }
    .announcement-bar--sale .page-width {
      width: 100% !important;
      max-width: 100% !important;
      overflow: hidden !important;
      padding: 0 !important;
      display: block !important;
      text-align: left !important;
    }

    /* ---- Endless marquee — repeating UCI flag + wordmark tile ---- */
    .uci-marquee {
      width: 100%;
      height: 32px;
      overflow: hidden;
      display: flex;
      align-items: center;
    }
    .uci-marquee__track {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      width: max-content;
      /* Duration is tuned against the actual track width (half the total,
         since the track is two identical copies) so the on-screen speed
         stays constant regardless of how many tiles are repeated — px/s
         is what matters for "feels slow", not the raw seconds value. */
      animation: uci-marquee-scroll 85s linear infinite;
      will-change: transform;
    }
    .announcement-bar--sale:hover .uci-marquee__track,
    .announcement-bar--sale:focus-within .uci-marquee__track {
      animation-play-state: paused;
    }
    @media (prefers-reduced-motion: reduce) {
      .uci-marquee__track {
        animation: none !important;
      }
    }
    @keyframes uci-marquee-scroll {
      from { transform: translateX(0); }
      /* Exactly -50% because the track is two identical halves — loops
         seamlessly regardless of viewport width or item count. */
      to   { transform: translateX(-50%); }
    }

    .uci-tile {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }
    .uci-tile__flag {
      width: 14px;
      height: 11px;
      flex-shrink: 0;
    }
    .uci-tile__word {
      display: inline-flex;
      align-items: baseline;
      gap: 5px;
      white-space: nowrap;
    }
    .uci-tile__uci {
      color: #ffffff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }
    .uci-tile__clearance {
      color: #ffffff;
      font-size: 12px;
      font-weight: 400;
      letter-spacing: 0.02em;
    }
    .uci-tile__sep {
      display: inline-flex;
      align-items: center;
      color: rgba(255, 255, 255, 0.55);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.06em;
      white-space: nowrap;
      margin: 0 22px;
    }
    .uci-tile__sep--brand {
      color: rgba(255, 255, 255, 0.85);
      font-weight: 700;
    }

    @media (max-width: 749px) {
      .uci-tile__flag {
        width: 12px;
        height: 9px;
      }
      .uci-tile__uci {
        font-size: 12px;
      }
      .uci-tile__clearance {
        font-size: 11px;
      }
      .uci-tile__sep {
        font-size: 10px;
        margin: 0 16px;
      }
    }

    .announcement-bar--sale .announcement-bar__close path {
      fill: #ffffff !important;
    }
  </style>
{% endif %}

<div id="announcement-bar">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'announcement' -%}
        <div style="background-color: {% if section.settings.sale_mode %}#1a1a1a{% else %}{{block.settings.bg_color}}{% endif %};" class="announcement-bar{% if section.settings.sale_mode %} announcement-bar--sale{% endif %} gradient{% unless forloop.first %} hidden{% endunless %}" role="region" aria-label="{{ 'sections.header.announcement' | t }}" {{ block.shopify_attributes }}>
          {%- if block.settings.text != blank -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
            {%- endif -%}
                <div class="page-width">
                  {% if section.settings.sale_mode %}
                    <div class="uci-marquee">
                      <div class="uci-marquee__track">
                        {%- for i in (1..8) -%}
                          {%- render 'uci-warehouse-tile', size: 'sm' -%}
                          <span class="uci-tile__sep">Sale + 1 free</span>
                          <span class="uci-tile__sep uci-tile__sep--brand">Sockeloen</span>
                        {%- endfor -%}
                        {%- for i in (1..8) -%}
                          {%- render 'uci-warehouse-tile', size: 'sm' -%}
                          <span class="uci-tile__sep">Sale + 1 free</span>
                          <span class="uci-tile__sep uci-tile__sep--brand">Sockeloen</span>
                        {%- endfor -%}
                      </div>
                    </div>
                  {% else %}
                    <p style="color: {{block.settings.font_color}};" class="announcement-bar__message {{ block.settings.text_alignment }} h5">
                      {% if localization.country.iso_code == 'US' %}
                        {{ block.settings.usd_text | escape }}
                      {% else %}
                        {{ block.settings.text | escape }}
                      {% endif %}
                      {%- if block.settings.link != blank -%}
                        {% render 'icon-arrow' %}
                      {%- endif -%}
                    </p>
                  {% endif %}
                </div>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          {%- endif -%}
          <div class="announcement-bar__close absolute cursor-pointer">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path style="fill: {{block.settings.font_color}};" fill-rule="evenodd" clip-rule="evenodd" d="M4.00394 4.71056L6.65039 7.35701L7.3575 6.6499L4.71105 4.00346L7.3575 1.35701L6.65039 0.649902L4.00394 3.29635L1.3575 0.649902L0.650391 1.35701L3.29684 4.00346L0.650391 6.6499L1.3575 7.35701L4.00394 4.71056Z" fill="white"/>
            </svg>
          </div>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</div>

<script>
  var announcementBarInterval = undefined;
  if(document.querySelectorAll('.announcement-bar').length > 1) {
    let count = 1, barCount = document.querySelectorAll('.announcement-bar').length;
    announcementBarInterval = setInterval(function(){
      document.querySelectorAll('.announcement-bar').forEach((bar, index) => {
        if(count == index) bar.classList.remove('hidden');
        else bar.classList.add('hidden');
      });
      count++;
      if(count >= barCount) count = 0;
    }, Number('{{ section.settings.autoplay_speed | times: 1000 }}'));
  }

  document.querySelectorAll('.announcement-bar__close').forEach(btn => {
    btn.addEventListener('click', function(){
      if(announcementBarInterval) clearInterval(announcementBarInterval);
      document.querySelectorAll('.announcement-bar').forEach(bar => {
        bar.classList.add('hidden');
      });
    });
  });

</script>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "sale_mode",
      "label": "UCI Warehouse Sale mode",
      "default": false,
      "info": "Enables black background with UCI rainbow stripes"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "default": 5,
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable Sticky",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "text",
          "id": "usd_text",
          "label": "Text on US Market",
          "default": "FREE SHIPPING > $150 // BORN IN THE PELOTON // 100% SATISFACTION // CUSTOMER IS KING //"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.label"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "font_color",
          "label": "Font color",
          "default": "#fff"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
