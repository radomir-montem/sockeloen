{% if section.settings.enable_sticky %}
  <style>
    #shopify-section-announcement-bar {
      position: sticky;
      top: 0;
    }

    .shopify-section-header-sticky {
      top: var(--announcemet-bar-height, 38px);
    }

    @media (max-width: 749px) {
      .shopify-section-header-sticky {
        top: var(--announcemet-bar-height, 52px);
      }
    }
  </style>
{% endif %}

<div id="announcement-bar">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'announcement' -%}
        <div style="background-color: {{block.settings.bg_color}};" class="announcement-bar gradient{% unless forloop.first %} hidden{% endunless %}" role="region" aria-label="{{ 'sections.header.announcement' | t }}" {{ block.shopify_attributes }}>
          {%- if block.settings.text != blank -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
            {%- endif -%}
                <div class="page-width">
                  <p style="color: {{block.settings.font_color}};" class="announcement-bar__message {{ block.settings.text_alignment }} h5">
                    {% if localization.country.iso_code == 'US' %}
                      {{ block.settings.usd_text | escape }}
                    {% else %}
                      {{ block.settings.text | escape }}
                    {% endif %}
                    {%- if block.settings.link != blank -%}
                      {% render 'icon-arrow' %}
                    {%- endif -%}
                  </p>
                </div>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          {%- endif -%}
          <div class="announcement-bar__close absolute cursor-pointer">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path style="fill: {{block.settings.font_color}};" fill-rule="evenodd" clip-rule="evenodd" d="M4.00394 4.71056L6.65039 7.35701L7.3575 6.6499L4.71105 4.00346L7.3575 1.35701L6.65039 0.649902L4.00394 3.29635L1.3575 0.649902L0.650391 1.35701L3.29684 4.00346L0.650391 6.6499L1.3575 7.35701L4.00394 4.71056Z" fill="white"/>
            </svg>
          </div>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</div>

<script>
  var announcementBarInterval = undefined;
  if(document.querySelectorAll('.announcement-bar').length > 1) {
    let count = 1, barCount = document.querySelectorAll('.announcement-bar').length;
    announcementBarInterval = setInterval(function(){
      document.querySelectorAll('.announcement-bar').forEach((bar, index) => {
        if(count == index) bar.classList.remove('hidden');
        else bar.classList.add('hidden');
      });
      count++;
      if(count >= barCount) count = 0;
    }, Number('{{ section.settings.autoplay_speed | times: 1000 }}'));
  }

  document.querySelectorAll('.announcement-bar__close').forEach(btn => {
    btn.addEventListener('click', function(){
      if(announcementBarInterval) clearInterval(announcementBarInterval);
      document.querySelectorAll('.announcement-bar').forEach(bar => {
        bar.classList.add('hidden');
      });
    });
  });

  /* Marquee effect — when the message is wider than the pill, duplicate it
     into a flex track and scroll it continuously so the text stays readable
     within the fixed pill width. Falls back to ellipsis (set by CSS) when
     the text fits. */
  (function initAnnouncementMarquee(){
    var WRAPPER_CLASS = 'announcement-bar__marquee-track';
    var SPEED_PX_PER_SEC = 55;  /* marquee speed; lower = slower */

    function reset(bar) {
      var track = bar.querySelector('.' + WRAPPER_CLASS);
      if (!track) return;
      var pageWidth = bar.querySelector('.page-width');
      if (!pageWidth) return;
      var original = track.querySelector('.announcement-bar__message:not([data-marquee-clone])');
      if (original && pageWidth) {
        pageWidth.innerHTML = '';
        pageWidth.appendChild(original);
      }
      bar.classList.remove('is-marquee');
    }

    function apply(bar) {
      var pageWidth = bar.querySelector('.page-width');
      var msg = bar.querySelector('.announcement-bar__message');
      if (!pageWidth || !msg) return;

      reset(bar);

      /* Measure — need bar to be visible to get real widths. */
      var wasHidden = bar.classList.contains('hidden');
      var prevDisplay, prevVisibility, prevPosition;
      if (wasHidden) {
        prevDisplay = bar.style.display;
        prevVisibility = bar.style.visibility;
        prevPosition = bar.style.position;
        bar.style.display = 'flex';
        bar.style.visibility = 'hidden';
        bar.style.position = 'absolute';
        bar.classList.remove('hidden');
      }

      /* Force nowrap to measure the un-ellipsed text width. */
      var prevWhitespace = msg.style.whiteSpace;
      var prevOverflow = msg.style.overflow;
      var prevTextOverflow = msg.style.textOverflow;
      msg.style.whiteSpace = 'nowrap';
      msg.style.overflow = 'visible';
      msg.style.textOverflow = 'clip';
      var textWidth = msg.scrollWidth;
      var containerWidth = pageWidth.clientWidth;
      msg.style.whiteSpace = prevWhitespace;
      msg.style.overflow = prevOverflow;
      msg.style.textOverflow = prevTextOverflow;

      if (wasHidden) {
        bar.classList.add('hidden');
        bar.style.display = prevDisplay;
        bar.style.visibility = prevVisibility;
        bar.style.position = prevPosition;
      }

      /* Tolerance — avoid flicker on 1-2px sub-pixel measurement noise. */
      if (textWidth <= containerWidth + 4) return;

      /* Build the marquee track: [msg][clone]. CSS handles the -50% shift. */
      var track = document.createElement('div');
      track.className = WRAPPER_CLASS;
      msg.parentElement.removeChild(msg);
      track.appendChild(msg);
      var clone = msg.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      clone.setAttribute('data-marquee-clone', '');
      track.appendChild(clone);
      pageWidth.appendChild(track);

      /* Duration scales with text length so very long messages don't whip by
         too fast. +60 for the padding-right gap inside the track. */
      var duration = Math.max(12, (textWidth + 60) / SPEED_PX_PER_SEC);
      track.style.setProperty('--marquee-duration', duration.toFixed(1) + 's');
      bar.classList.add('is-marquee');
    }

    function applyAll() {
      document.querySelectorAll('#announcement-bar .announcement-bar').forEach(apply);
    }

    /* Initial pass, then re-measure on resize (debounced) and when fonts load. */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyAll);
    } else {
      applyAll();
    }
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(applyAll);
    }
    var resizeTimer;
    window.addEventListener('resize', function(){
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(applyAll, 180);
    });
  })();

</script>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "default": 5,
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable Sticky",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "text",
          "id": "usd_text",
          "label": "Text on US Market",
          "default": "FREE SHIPPING > $150 // BORN IN THE PELOTON // 100% SATISFACTION // CUSTOMER IS KING //"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.label"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "default": "#000"
        },
        {
          "type": "color",
          "id": "font_color",
          "label": "Font color",
          "default": "#fff"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
