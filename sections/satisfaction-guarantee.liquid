{{ 'section-satisfaction-guarantee.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --satisfaction-bg: {{ section.settings.background_color }};
    --satisfaction-text: {{ section.settings.text_color }};
    --satisfaction-accent: {{ section.settings.accent_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="satisfaction-guarantee section-{{ section.id }}">
  <div class="satisfaction-guarantee__container">
    <div class="satisfaction-guarantee__inner satisfaction-guarantee__reveal">
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2 class="satisfaction-guarantee__heading">
          {{- section.settings.heading | escape }}
          {%- if section.settings.heading_italic != blank %}
            <em>{{ section.settings.heading_italic | escape }}</em>
          {%- endif -%}
        </h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="satisfaction-guarantee__body">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        {%- if section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="satisfaction-guarantee__button">
            {{- section.settings.button_text | escape -}}
          </a>
        {%- else -%}
          <button type="button" class="satisfaction-guarantee__button" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
            {{- section.settings.button_text | escape -}}
          </button>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var el = document.querySelector('.section-{{ section.id }} .satisfaction-guarantee__reveal');
    if (!el) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.classList.add('is-visible');
      return;
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(el);
  })();
</script>

{% schema %}
{
  "name": "Satisfaction Guarantee",
  "tag": "section",
  "class": "satisfaction-guarantee-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not 100% satisfied?"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic accent",
      "default": "No problem!"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>At Sockeloen, the customer is king. We stand behind every pair of socks we make with our 100% satisfaction guarantee. Not happy with your order? Simply reach out within 30 days and we'll make it right — whether that's an exchange, store credit, or a full refund. No hassle, no fine print.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "info": "Leave blank to scroll to top of page."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d4eaf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F76503"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "templates": ["product"],
  "presets": [
    {
      "name": "Satisfaction Guarantee"
    }
  ]
}
{% endschema %}
