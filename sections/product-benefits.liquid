{{ 'section-main-product-v2.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="product-benefits-section section-{{ section.id }}-padding"
  style="{% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background-color: {{ section.settings.background_color }};{% endif %} color: {{ section.settings.text_color }};"
>
  {%- for block in section.blocks -%}
    <div class="product-benefit" {{ block.shopify_attributes }}>
      {%- if block.settings.video != blank -%}
        {%- comment -%} Video takes priority over image {%- endcomment -%}
        <div class="product-benefit__media">
          <video
            class="product-benefit__video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 750 }}{%- endif -%}"
          >
            {%- for source in block.settings.video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- elsif block.settings.video_url != blank -%}
        {%- comment -%} External MP4 URL fallback {%- endcomment -%}
        <div class="product-benefit__media">
          <video
            class="product-benefit__video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 750 }}{%- endif -%}"
          >
            <source src="{{ block.settings.video_url }}" type="video/mp4">
          </video>
        </div>
      {%- elsif block.settings.image != blank -%}
        <div class="product-benefit__media">
          <img
            srcset="
              {% if block.settings.image.width >= 375 %}{{ block.settings.image | image_url: width: 375 }} 375w,{% endif %}
              {% if block.settings.image.width >= 550 %}{{ block.settings.image | image_url: width: 550 }} 550w,{% endif %}
              {% if block.settings.image.width >= 750 %}{{ block.settings.image | image_url: width: 750 }} 750w,{% endif %}
              {% if block.settings.image.width >= 1100 %}{{ block.settings.image | image_url: width: 1100 }} 1100w,{% endif %}
              {% if block.settings.image.width >= 1500 %}{{ block.settings.image | image_url: width: 1500 }} 1500w,{% endif %}
              {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
            "
            src="{{ block.settings.image | image_url: width: 750 }}"
            sizes="(min-width: 990px) 50vw, 100vw"
            alt="{{ block.settings.image.alt | escape | default: block.settings.heading }}"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div class="product-benefit__content">
        {%- if block.settings.heading != blank -%}
          <h3 class="product-benefit__heading">
            {{ block.settings.heading }}
            {%- if block.settings.heading_italic != blank -%}
              <em>{{ block.settings.heading_italic }}</em>
            {%- endif -%}
          </h3>
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <div class="product-benefit__description rte">
            {{ block.settings.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>

<script>
  (function() {
    /* Scroll-triggered reveal */
    var benefits = document.querySelectorAll('.product-benefit');
    if (!benefits.length || !('IntersectionObserver' in window)) {
      benefits.forEach(function(b) { b.classList.add('is-visible'); });
      return;
    }
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);

          /* Start video playback when visible */
          var video = entry.target.querySelector('video');
          if (video) {
            video.play().catch(function() {});
          }
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    benefits.forEach(function(b) { observer.observe(b); });
  })();
</script>

{% schema %}
{
  "name": "Product Benefits",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a video via Shopify Files. Autoplays muted and loops. Takes priority over image."
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "External video URL (MP4)",
          "info": "Direct link to an MP4 file. Only used if no Shopify video is selected above."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image / Video poster",
          "info": "Shown as fallback when no video is set, or as poster frame while video loads."
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Headline",
          "default": "Product benefit"
        },
        {
          "type": "text",
          "id": "heading_italic",
          "label": "Italic headline portion",
          "info": "Appended after the main headline in italics"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color (leave empty to match page)",
      "default": "#f5f1eb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product Benefits",
      "blocks": [
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
