{%- comment -%}
  Product carousel logic:
  1. "Recently viewed" — fully client-side (if selected)
  2. First 3 slots: product source metafield / manual list / fallback upsells metafield
  3. Remaining slots (up to max): filled from Collection setting (no duplicates)
  4. If nothing else: global upsells fallback
{%- endcomment -%}

{%- liquid
  assign source_products = nil
  assign is_recently_viewed = false
  assign swiper_id = 'bot-swiper-' | append: section.id
  assign max_items = section.settings.max_products
  assign metafield_limit = 3

  if section.settings.product_source == 'recently_viewed'
    assign is_recently_viewed = true
  else
    comment
      Step 1: Gather metafield products (first 3 slots)
    endcomment
    assign meta_products = nil
    if section.settings.product_source != 'none' and section.settings.product_source != 'recently_viewed'
      assign meta_key = section.settings.product_source
      if meta_key == 'my_fields.product_upsells'
        assign meta_products = product.metafields.my_fields.product_upsells.value
      elsif meta_key == 'my_fields.collection_upsell'
        assign meta_products = product.metafields.my_fields.collection_upsell.value.products
      elsif meta_key == 'custom.related_products'
        assign meta_products = product.metafields.custom.related_products.value
      elsif meta_key == 'custom.cross_sell'
        assign meta_products = product.metafields.custom.cross_sell.value
      elsif meta_key != blank
        assign meta_parts = meta_key | split: '.'
        if meta_parts.size == 2
          assign meta_ns = meta_parts[0]
          assign meta_k = meta_parts[1]
          assign meta_products = product.metafields[meta_ns][meta_k].value
        endif
      endif
    elsif section.settings.product_list != blank and section.settings.product_list.size > 0
      assign meta_products = section.settings.product_list
    endif

    comment
      No fallback to metafields when 'none' is selected — only collection fills the carousel
    endcomment

    comment
      Step 2: Build combined list — metafield products first (up to 3), then fill from collection (up to max)
    endcomment
    assign combined_handles = ''
    assign combined_count = 0

    if meta_products != blank
      for item in meta_products
        if combined_count >= metafield_limit
          break
        endif
        if item.handle != product.handle and item.available
          if combined_handles == ''
            assign combined_handles = item.handle
          else
            assign combined_handles = combined_handles | append: ',' | append: item.handle
          endif
          assign combined_count = combined_count | plus: 1
        endif
      endfor
    endif

    comment
      Step 3: Fill remaining slots from collection
    endcomment
    if section.settings.collection != blank and combined_count < max_items
      for col_product in section.settings.collection.products
        if combined_count >= max_items
          break
        endif
        if col_product.handle == product.handle
          continue
        endif
        if col_product.available == false
          continue
        endif
        assign already_added = false
        assign handle_check = combined_handles | split: ','
        for h in handle_check
          if h == col_product.handle
            assign already_added = true
            break
          endif
        endfor
        unless already_added
          if combined_handles == ''
            assign combined_handles = col_product.handle
          else
            assign combined_handles = combined_handles | append: ',' | append: col_product.handle
          endif
          assign combined_count = combined_count | plus: 1
        endunless
      endfor
    endif

    comment
      Step 4: If still no products, fall back to global upsells
    endcomment
    if combined_count == 0 and settings.global_upsells != blank
      for fallback_product in settings.global_upsells.products
        if combined_count >= max_items
          break
        endif
        if fallback_product.handle != product.handle and fallback_product.available
          if combined_handles == ''
            assign combined_handles = fallback_product.handle
          else
            assign combined_handles = combined_handles | append: ',' | append: fallback_product.handle
          endif
          assign combined_count = combined_count | plus: 1
        endif
      endfor
    endif

    assign combined_handle_array = combined_handles | split: ','
  endif
-%}

{%- style -%}
  .bot-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .bot-section-{{ section.id }} .bot-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-align: {{ section.settings.heading_alignment }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    padding: 0 16px 16px;
  }
  .bot-section-{{ section.id }} .bot-heading em {
    font-style: italic;
    color: {{ section.settings.heading_italic_color }};
  }
  @media screen and (max-width: 749px) {
    .bot-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    .bot-section-{{ section.id }} .bot-heading {
      font-size: {{ section.settings.heading_size | times: 0.8 | round: 0 }}px;
    }
  }
  /* Ensure single-row carousel */
  .{{ swiper_id }} .swiper-wrapper {
    flex-wrap: nowrap !important;
  }
  /* Hover: crossfade to second image */
  .bot-section-{{ section.id }} .media.media--hover-effect > img {
    transition: opacity 0.35s ease;
  }
  .bot-section-{{ section.id }} .card-wrapper:hover .media.media--hover-effect:not(.no-has-second-image) > img:first-child:not(:only-child) {
    opacity: 0;
  }
  .bot-section-{{ section.id }} .card-wrapper:hover .media.media--hover-effect > img + img {
    opacity: 1;
  }
  .bot-section-{{ section.id }} .card-wrapper:hover .media.media--hover-effect:not(.no-has-second-image) > img:first-child {
    display: block !important;
  }
{%- endstyle -%}

{%- if is_recently_viewed or combined_handle_array != blank and combined_handle_array.size > 0 -%}
<div class="bot-section-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h4 class="bot-heading">
      {{- section.settings.heading -}}
      {%- if section.settings.heading_italic != blank -%}
        {{ ' ' }}<em>{{ section.settings.heading_italic }}</em>
      {%- endif -%}
    </h4>
  {%- endif -%}

  <div class="{{ swiper_id }} bot-swiper overflow-hidden relative">
    <div class="swiper-wrapper">
      {%- unless is_recently_viewed -%}
        {%- for handle in combined_handle_array -%}
          {%- assign carouselProduct = all_products[handle] -%}
          {%- if carouselProduct != blank -%}
            <div class="swiper-slide">
              {% render 'card-product',
                card_product: carouselProduct,
                media_aspect_ratio: section.settings.image_ratio,
                section_id: section.id,
                show_secondary_image: true
              %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endunless -%}
    </div>
    <div class="{{ swiper_id }}-next bot-swiper-next">
      {% render 'icon-arrow-right' %}
    </div>
    <div class="{{ swiper_id }}-prev bot-swiper-prev">
      {% render 'icon-arraw-left' %}
    </div>
  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var swiperId = '{{ swiper_id }}';
    var isRecentlyViewed = {{ is_recently_viewed }};
    var maxProducts = {{ section.settings.max_products }};
    var mobileColumns = {{ section.settings.mobile_columns }};
    var desktopColumns = {{ section.settings.desktop_columns }};
    var imageRatio = '{{ section.settings.image_ratio }}';

    function initSwiper() {
      if (typeof window.Swiper === 'undefined') {
        setTimeout(initSwiper, 100);
        return;
      }
      var el = document.querySelector('.' + swiperId);
      if (!el) return;
      new window.Swiper(el, {
        direction: 'horizontal',
        slidesPerView: mobileColumns,
        spaceBetween: 5,
        navigation: {
          nextEl: '.' + swiperId + '-next',
          prevEl: '.' + swiperId + '-prev'
        },
        preventClicks: false,
        breakpoints: {
          768: { slidesPerView: desktopColumns }
        }
      });
    }

    function loadRecentlyViewed() {
      var stored = localStorage.getItem('recentlyViewedProduct');
      if (!stored) {
        /* Hide section if no recently viewed products */
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      var products;
      try { products = JSON.parse(stored); } catch(e) { return; }
      if (!products || !products.length) {
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      /* Filter out current product */
      var currentHandle = '{{ product.handle }}';
      products = products.filter(function(p) { return p.productHandle !== currentHandle; });
      if (!products.length) {
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      /* Limit to max_products */
      products = products.slice(0, maxProducts);

      var wrapper = document.querySelector('.' + swiperId + ' .swiper-wrapper');
      if (!wrapper) return;

      var fetches = products.map(function(item) {
        return fetch('/products/' + item.productHandle + '?section_id=card-product')
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var card = doc.querySelector('.shopify-section');
            return card ? card.innerHTML : null;
          })
          .catch(function() { return null; });
      });

      Promise.all(fetches).then(function(cards) {
        var html = '';
        cards.forEach(function(card) {
          if (card) html += '<div class="swiper-slide">' + card + '</div>';
        });
        if (html) {
          wrapper.innerHTML = html;
          initSwiper();
        } else {
          var section = document.querySelector('.bot-section-' + sectionId);
          if (section) section.style.display = 'none';
        }
      });
    }

    if (isRecentlyViewed) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadRecentlyViewed);
      } else {
        loadRecentlyViewed();
      }
    } else {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSwiper);
      } else {
        initSwiper();
      }
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product source"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product source (metafield / recently viewed)",
      "info": "Select a metafield or 'Recently viewed'. First 3 slots come from this source, remaining slots are filled from the Collection below.",
      "options": [
        { "value": "none", "label": "— None (use manual list, collection, or fallback)" },
        { "value": "recently_viewed", "label": "Recently viewed products" },
        { "value": "my_fields.product_upsells", "label": "Upsells (my_fields.product_upsells)" },
        { "value": "my_fields.collection_upsell", "label": "Collection upsell (my_fields.collection_upsell)" },
        { "value": "custom.related_products", "label": "Related products (custom.related_products)" },
        { "value": "custom.cross_sell", "label": "Cross-sell (custom.cross_sell)" }
      ],
      "default": "none"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Manual product list",
      "info": "Highest priority (except Recently viewed). Pick specific products."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used to fill remaining carousel slots after metafield products."
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Max products to show",
      "default": 8
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete your order"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic portion",
      "info": "Appended after the heading in italics"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 30
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Italic portion color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait (4:5)" }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Desktop columns",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobile columns",
      "default": 2
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}
