{%- comment -%}
  Product source priority:
  1. "Recently viewed" (client-side, from localStorage)
  2. Manual product list (section setting)
  3. Collection (section setting)
  4. Product metafield (dropdown selection)
  5. Global upsells fallback
{%- endcomment -%}

{%- liquid
  assign source_products = nil
  assign is_recently_viewed = false
  assign swiper_id = 'bot-swiper-' | append: section.id

  if section.settings.product_source == 'recently_viewed'
    assign is_recently_viewed = true
  elsif section.settings.product_list != blank and section.settings.product_list.size > 0
    assign source_products = section.settings.product_list
  elsif section.settings.collection != blank and section.settings.collection.products.size > 0
    assign source_products = section.settings.collection.products
  elsif section.settings.product_source != 'none' and section.settings.product_source != 'recently_viewed'
    assign meta_key = section.settings.product_source
    if meta_key == 'my_fields.product_upsells'
      assign meta_value = product.metafields.my_fields.product_upsells.value
    elsif meta_key == 'my_fields.collection_upsell'
      assign meta_value = product.metafields.my_fields.collection_upsell.value.products
    elsif meta_key == 'custom.related_products'
      assign meta_value = product.metafields.custom.related_products.value
    elsif meta_key == 'custom.cross_sell'
      assign meta_value = product.metafields.custom.cross_sell.value
    elsif meta_key != blank
      assign meta_parts = meta_key | split: '.'
      if meta_parts.size == 2
        assign meta_ns = meta_parts[0]
        assign meta_k = meta_parts[1]
        assign meta_value = product.metafields[meta_ns][meta_k].value
      endif
    endif
    if meta_value != blank
      assign source_products = meta_value
    endif
  endif

  unless is_recently_viewed
    if source_products == nil or source_products == blank
      if product.metafields.my_fields.product_upsells.value != blank
        assign source_products = product.metafields.my_fields.product_upsells.value
      else
        assign source_products = settings.global_upsells.products
      endif
    endif
  endunless
-%}

{%- style -%}
  .bot-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .bot-section-{{ section.id }} .bot-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-align: {{ section.settings.heading_alignment }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    padding: 0 16px 16px;
  }
  .bot-section-{{ section.id }} .bot-heading em {
    font-style: italic;
    color: {{ section.settings.heading_italic_color }};
  }
  @media screen and (max-width: 749px) {
    .bot-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    .bot-section-{{ section.id }} .bot-heading {
      font-size: {{ section.settings.heading_size | times: 0.8 | round: 0 }}px;
    }
  }
  /* Ensure single-row carousel */
  .{{ swiper_id }} .swiper-wrapper {
    flex-wrap: nowrap !important;
  }
{%- endstyle -%}

{%- if is_recently_viewed or source_products != blank and source_products.size > 0 -%}
<div class="bot-section-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h4 class="bot-heading">
      {{- section.settings.heading -}}
      {%- if section.settings.heading_italic != blank -%}
        {{ ' ' }}<em>{{ section.settings.heading_italic }}</em>
      {%- endif -%}
    </h4>
  {%- endif -%}

  <div class="{{ swiper_id }} bot-swiper overflow-hidden relative">
    <div class="swiper-wrapper">
      {%- unless is_recently_viewed -%}
        {%- for productItem in source_products limit: section.settings.max_products -%}
          <div class="swiper-slide">
            {% render 'card-product',
              card_product: productItem,
              media_aspect_ratio: section.settings.image_ratio,
              section_id: section.id,
              show_secondary_image: true
            %}
          </div>
        {%- endfor -%}
      {%- endunless -%}
    </div>
    <div class="{{ swiper_id }}-next bot-swiper-next">
      {% render 'icon-arrow-right' %}
    </div>
    <div class="{{ swiper_id }}-prev bot-swiper-prev">
      {% render 'icon-arraw-left' %}
    </div>
  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var swiperId = '{{ swiper_id }}';
    var isRecentlyViewed = {{ is_recently_viewed }};
    var maxProducts = {{ section.settings.max_products }};
    var mobileColumns = {{ section.settings.mobile_columns }};
    var desktopColumns = {{ section.settings.desktop_columns }};
    var imageRatio = '{{ section.settings.image_ratio }}';

    function initSwiper() {
      if (typeof window.Swiper === 'undefined') {
        setTimeout(initSwiper, 100);
        return;
      }
      var el = document.querySelector('.' + swiperId);
      if (!el) return;
      new window.Swiper(el, {
        direction: 'horizontal',
        slidesPerView: mobileColumns,
        spaceBetween: 5,
        navigation: {
          nextEl: '.' + swiperId + '-next',
          prevEl: '.' + swiperId + '-prev'
        },
        preventClicks: false,
        breakpoints: {
          768: { slidesPerView: desktopColumns }
        }
      });
    }

    function loadRecentlyViewed() {
      var stored = localStorage.getItem('recentlyViewedProduct');
      if (!stored) {
        /* Hide section if no recently viewed products */
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      var products;
      try { products = JSON.parse(stored); } catch(e) { return; }
      if (!products || !products.length) {
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      /* Filter out current product */
      var currentHandle = '{{ product.handle }}';
      products = products.filter(function(p) { return p.productHandle !== currentHandle; });
      if (!products.length) {
        var section = document.querySelector('.bot-section-' + sectionId);
        if (section) section.style.display = 'none';
        return;
      }

      /* Limit to max_products */
      products = products.slice(0, maxProducts);

      var wrapper = document.querySelector('.' + swiperId + ' .swiper-wrapper');
      if (!wrapper) return;

      var fetches = products.map(function(item) {
        return fetch('/products/' + item.productHandle + '?section_id=card-product')
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var card = doc.querySelector('.shopify-section');
            return card ? card.innerHTML : null;
          })
          .catch(function() { return null; });
      });

      Promise.all(fetches).then(function(cards) {
        var html = '';
        cards.forEach(function(card) {
          if (card) html += '<div class="swiper-slide">' + card + '</div>';
        });
        if (html) {
          wrapper.innerHTML = html;
          initSwiper();
        } else {
          var section = document.querySelector('.bot-section-' + sectionId);
          if (section) section.style.display = 'none';
        }
      });
    }

    if (isRecentlyViewed) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadRecentlyViewed);
      } else {
        loadRecentlyViewed();
      }
    } else {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSwiper);
      } else {
        initSwiper();
      }
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product source"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product source (metafield / recently viewed)",
      "info": "Select a metafield or 'Recently viewed'. Manual list and Collection below take priority if filled.",
      "options": [
        { "value": "none", "label": "— None (use manual list, collection, or fallback)" },
        { "value": "recently_viewed", "label": "Recently viewed products" },
        { "value": "my_fields.product_upsells", "label": "Upsells (my_fields.product_upsells)" },
        { "value": "my_fields.collection_upsell", "label": "Collection upsell (my_fields.collection_upsell)" },
        { "value": "custom.related_products", "label": "Related products (custom.related_products)" },
        { "value": "custom.cross_sell", "label": "Cross-sell (custom.cross_sell)" }
      ],
      "default": "none"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Manual product list",
      "info": "Highest priority (except Recently viewed). Pick specific products."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used if no manual products are selected."
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Max products to show",
      "default": 8
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete your order"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic portion",
      "info": "Appended after the heading in italics"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 30
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Italic portion color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait (4:5)" }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Desktop columns",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobile columns",
      "default": 2
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}
