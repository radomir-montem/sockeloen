{% if product.metafields.my_fields.product_upsells.value != blank %}
  {% assign products = product.metafields.my_fields.product_upsells.value %}
{% else %}
  {% assign products = settings.global_upsells.products %}
{% endif %}

{%- style -%}
  .bot-section-{{ section.id }} .bot-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-align: {{ section.settings.heading_alignment }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    padding: 12px {{ section.settings.heading_alignment | replace: 'left', '16px' | replace: 'center', '0' | replace: 'right', '16px' }} 16px;
  }
  .bot-section-{{ section.id }} .bot-heading em {
    font-style: italic;
    color: {{ section.settings.heading_italic_color }};
  }
  @media screen and (max-width: 749px) {
    .bot-section-{{ section.id }} .bot-heading {
      font-size: {{ section.settings.heading_size | times: 0.8 | round: 0 }}px;
      padding-left: 16px;
      padding-right: 16px;
    }
  }
{%- endstyle -%}

<div class="bg-white pt-0 bot-section-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h4 class="bot-heading">
      {{- section.settings.heading -}}
      {%- if section.settings.heading_italic != blank -%}
        <em>{{ section.settings.heading_italic }}</em>
      {%- endif -%}
    </h4>
  {%- endif -%}

  <div class="bot-swiper overflow-hidden relative">
    <div class="swiper-wrapper">
      {% for productItem in products %}
        <div class="swiper-slide">
          {% render 'card-product', card_product: productItem, media_aspect_ratio: 'adapt', section_id: section.id, show_secondary_image: true %}
        </div>
      {% endfor %}
    </div>
    <div class="bot-swiper-next">
      {% render 'icon-arrow-right' %}
    </div>
    <div class="bot-swiper-prev">
      {% render 'icon-arraw-left' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bought Often Together",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete your order"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic portion",
      "info": "Appended after the heading in italics"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 30
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_italic_color",
      "label": "Italic portion color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Bought Often Together"
    }
  ]
}
{% endschema %}
