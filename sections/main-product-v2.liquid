  <script>
    (function() {
      function initAtcFix() {
        var form = document.getElementById('product-form-{{ section.id }}');
        if (!form) return;
        var btn = form.querySelector('[name="add"]');
        if (!btn) return;
        var productAvailable = {{ product.selected_or_first_available_variant.available | json }};
        var comingSoon = {{ product.metafields.custom.coming_soon | default: false | json }};
        if (!productAvailable || comingSoon) return;

        btn.removeAttribute('disabled');
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (m.attributeName === 'disabled' && btn.disabled) {
              var input = form.querySelector('input[name="id"]');
              if (input && input.value) {
                btn.removeAttribute('disabled');
              }
            }
          });
        });
        observer.observe(btn, { attributes: true, attributeFilter: ['disabled'] });
        setTimeout(function() { observer.disconnect(); }, 5000);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAtcFix);
      } else {
        initAtcFix();
      }
    })();
  </script>

  {%- comment -%}
    Variant image filtering for product-v2.
    This script runs during HTML parsing (before global.js defines the custom element).
    Our change listener is therefore registered BEFORE the constructor's onVariantChange
    listener. When a change event fires, our listener would run first — before
    currentVariant is updated. We use setTimeout(fn, 0) to defer our filter to run
    after all synchronous change handlers (including onVariantChange) have completed.
  {%- endcomment -%}
  <script>
    (function() {
      var sectionSelector = '#MainProduct-{{ section.id }}';

      function filterVariantMedia(el, skipPrepend) {
        if (!el.currentVariant || !el.currentVariant.featured_media) return;
        var selectedAlt = el.currentVariant.featured_media.alt;
        if (!selectedAlt) return;
        var section = el.closest('[id^="MainProduct"]');
        if (!section || !section.querySelector('.product-v2')) return;

        /* Filter main media items by alt text */
        section.querySelectorAll('.product__media-item[data-variant-alt]').forEach(function(item) {
          item.style.display = (item.getAttribute('data-variant-alt') === selectedAlt) ? '' : 'none';
        });
        section.querySelectorAll('.product__media-item:not([data-variant-alt])').forEach(function(item) {
          item.style.display = '';
        });

        /* Filter thumbnails */
        section.querySelectorAll('.thumbnail-list__item[data-variant-alt]').forEach(function(item) {
          item.style.display = (item.getAttribute('data-variant-alt') === selectedAlt) ? '' : 'none';
        });

        /* Re-call setActiveMedia so slider resets pages with correct visible items.
         * On initial page load, skip prepend (DOM reorder) to prevent
         * scroll-anchoring jumps on mobile stacked layouts. */
        var shouldPrepend = !skipPrepend;
        var mediaGallery = section.querySelector('media-gallery');
        if (mediaGallery) {
          var mediaId = el.dataset.section + '-' + el.currentVariant.featured_media.id;
          var scrollY = window.scrollY;
          mediaGallery.setActiveMedia(mediaId, shouldPrepend);
          window.scrollTo(0, scrollY);
        }
      }

      function bindFilter(el) {
        /*
         * Use setTimeout(fn, 0) so our filter runs AFTER all synchronous change
         * handlers have completed (including onVariantChange which updates currentVariant).
         * This works regardless of listener registration order.
         */
        el.addEventListener('change', function() {
          setTimeout(function() { filterVariantMedia(el, false); }, 0);
        });

        /* Initial page load: connectedCallback fires onVariantChange after 500ms.
         * Pass skipPrepend=true to avoid DOM reorder that causes scroll jumps. */
        setTimeout(function() {
          filterVariantMedia(el, true);
        }, 600);
      }

      /* Attach as soon as variant-radios appears in the DOM */
      function tryBind() {
        var el = document.querySelector(sectionSelector + ' variant-radios');
        if (el) {
          bindFilter(el);
          return true;
        }
        return false;
      }

      /* Run immediately — this script is after variant-radios in the DOM */
      if (!tryBind()) {
        /* Fallback: watch for element */
        var obs = new MutationObserver(function() {
          if (tryBind()) obs.disconnect();
        });
        obs.observe(document.querySelector(sectionSelector) || document.body, { childList: true, subtree: true });
      }
    })();
  </script>

  <script>
    /* ── Mobile auto-scroll prevention ──────────────────────────────────
     * Third-party widgets (Taggbox, Reviews.io, Avada) call scrollIntoView
     * or similar during init, causing an unwanted scroll-down on mobile.
     * Fix: intercept and block programmatic scroll calls during the first
     * 2.5 s of page load. User-initiated scrolls (touch) are unaffected
     * because they don't go through scrollIntoView / window.scrollTo.    */
    (function() {
      if (window.innerWidth >= 750) return;

      var locked = true;
      var userScrolled = false;

      /* Detect real user interaction */
      var markUser = function() { userScrolled = true; };
      window.addEventListener('touchstart', markUser, { once: true, passive: true });

      /* ---- Block Element.scrollIntoView ---- */
      var origSIV = Element.prototype.scrollIntoView;
      Element.prototype.scrollIntoView = function() {
        if (locked) return;                    /* swallow during init */
        return origSIV.apply(this, arguments);
      };

      /* ---- Block window.scrollTo / window.scroll ---- */
      var origScrollTo = window.scrollTo;
      var origScroll   = window.scroll;
      var safeScrollTo = function() {
        if (locked && !userScrolled) {
          /* Allow our own scrollTo(0,0) restorations (args = 0,0) */
          var y = arguments.length === 1 ? arguments[0].top : arguments[1];
          if (y !== 0 && y !== undefined) return;   /* block non-zero scrolls */
        }
        return origScrollTo.apply(window, arguments);
      };
      window.scrollTo = safeScrollTo;
      window.scroll   = safeScrollTo;

      /* ---- Release after init window ---- */
      setTimeout(function() {
        locked = false;
        Element.prototype.scrollIntoView = origSIV;
        window.scrollTo = origScrollTo;
        window.scroll   = origScroll;
        window.removeEventListener('touchstart', markUser);
      }, 2500);
    })();
  </script>
</section>

{%- comment -%} ========== STICKY ATC V2 ========== {%- endcomment -%}
{% assign sticky_atc = product.metafields.custom.disable_sticky_atc | default: false %}
{% unless sticky_atc %}
  <sticky-atc-v2 data-section-id="{{ section.id }}">
    <div class="product-v2-sticky-bar">
      <div class="product-v2-sticky-bar__info">
        <span class="product-v2-sticky-bar__title">{{ product.title | escape }}</span>
        <span class="product-v2-sticky-bar__price">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
      </div>
      <ul class="product-v2-sticky-bar__usps">
        <li class="product-v2-sticky-bar__usp">{% render 'icon-checkmark' %}<span>{{ 'products.v2.sticky_usp_1' | t }}</span></li>
        <li class="product-v2-sticky-bar__usp">{% render 'icon-checkmark' %}<span>{{ 'products.v2.sticky_usp_2' | t }}</span></li>
        <li class="product-v2-sticky-bar__usp">{% render 'icon-checkmark' %}<span>{{ 'products.v2.sticky_usp_3' | t }}</span></li>
      </ul>
      <button
        type="button"
        class="product-v2-sticky-bar__atc-btn product-sticky-atc bg-black font-medium tracking-[0.02em] uppercase button button--primary"
      >
        <span>{{ 'products.product.add_to_cart' | t }}</span>
      </button>
    </div>

  </sticky-atc-v2>

  {%- comment -%} Size confirmation modal (outside sticky-atc-v2 so transform doesn't break fixed positioning) {%- endcomment -%}
  <div class="product-v2-size-modal" aria-hidden="true">
    <div class="product-v2-size-modal__backdrop"></div>
    <div class="product-v2-size-modal__content">
      <p class="product-v2-size-modal__heading">{{ 'products.v2.size_modal_heading' | t }}</p>
      <div class="product-v2-size-modal__size-display">
        <span class="product-v2-size-modal__selection"></span>
      </div>
      <div class="product-v2-size-modal__actions">
        <button type="button" class="product-v2-size-modal__confirm">{{ 'products.v2.size_modal_confirm' | t }}</button>
        <button type="button" class="product-v2-size-modal__change">{{ 'products.v2.size_modal_change' | t }}</button>
      </div>
    </div>
  </div>
{% endunless %}

