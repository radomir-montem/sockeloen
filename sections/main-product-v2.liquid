            {%- when 'shipping_info' -%}
              {%- comment -%}
                Ship date logic (v2):
                - Before 15:00 CET/CEST on a working day → shipped today
                - After 15:00 or on a weekend → shipped next working day
                - Automatically handles CET ↔ CEST via Intl timezone

                The secure_checkout block is also rendered here (after ship date, before USP accordions)
                so it always appears in the right visual position regardless of block order.
              {%- endcomment -%}
              <div id="shipment-message-v2" class="shipment-container !m-0 product-v2__trust-row product-v2__shipping-row" {{ block.shopify_attributes }}>
                <svg class="product-v2__shipping-icon" width="39" height="24" viewBox="0 0 39 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="38" height="23" rx="3.5" fill="#FFFFFF" stroke="#E0E0E0"/>
                  <g clip-path="url(#clip_ship_{{ section.id }})">
                    <path d="M15.2539 16.2399C17.1739 18.1666 20.1406 18.5599 22.4939 17.1999C24.8472 15.8466 25.9939 13.0732 25.2939 10.4532C24.5939 7.82658 22.2139 6.00659 19.5006 6.00659" stroke="#0F1A2B" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M13.5 12H13.5067" stroke="#0F1A2B" stroke-linecap="round"/>
                    <path d="M17.168 6.33325H17.1746" stroke="#0F1A2B" stroke-linecap="round"/>
                    <path d="M13.9531 14.2532H13.9598" stroke="#0F1A2B" stroke-linecap="round"/>
                    <path d="M13.9531 9.68652H13.9598" stroke="#0F1A2B" stroke-linecap="round"/>
                    <path d="M15.2461 7.74658H15.2528" stroke="#0F1A2B" stroke-linecap="round"/>
                    <path d="M19.0469 9.6001V12.3001L20.8535 14.1001" stroke="#0F1A2B" stroke-linecap="round" stroke-linejoin="round"/>
                  </g>
                  <defs>
                    <clipPath id="clip_ship_{{ section.id }}">
                      <rect width="16" height="16" fill="white" transform="translate(11.5 4)"/>
                    </clipPath>
                  </defs>
                </svg>
                <p class="shipping-text" id="ship-date-text" style="display:none;"></p>
              </div>
              <script>
                (function() {
                  var isNl = window.location.pathname.indexOf('/nl') !== -1;
                  var cutoffHour = 15;

                  function getNLTime() {
                    var opts = { timeZone: 'Europe/Amsterdam', hour: 'numeric', minute: 'numeric', hour12: false };
                    var parts = new Date().toLocaleString('en-GB', opts).split(':');
                    return { hour: parseInt(parts[0], 10), minute: parseInt(parts[1], 10) };
                  }

                  function getNLDay() {
                    var dayStr = new Date().toLocaleString('en-GB', { timeZone: 'Europe/Amsterdam', weekday: 'short' });
                    return ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].indexOf(dayStr);
                  }

                  function formatDate(date) {
                    var dEN = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
                    var dNL = ['Zondag','Maandag','Dinsdag','Woensdag','Donderdag','Vrijdag','Zaterdag'];
                    var mEN = ['January','February','March','April','May','June','July','August','September','October','November','December'];
                    var mNL = ['Januari','Februari','Maart','April','Mei','Juni','Juli','Augustus','September','Oktober','November','December'];
                    var day = date.getDate();
                    var s = 'th';
                    if (day % 10 === 1 && day !== 11) s = 'st';
                    else if (day % 10 === 2 && day !== 12) s = 'nd';
                    else if (day % 10 === 3 && day !== 13) s = 'rd';
                    if (isNl) return dNL[date.getDay()] + ', ' + day + ' ' + mNL[date.getMonth()];
                    return dEN[date.getDay()] + ', ' + day + s + ' of ' + mEN[date.getMonth()];
                  }

                  function getNextWorkday() {
                    var d = new Date();
                    d.setDate(d.getDate() + 1);
                    while (d.getDay() === 0 || d.getDay() === 6) d.setDate(d.getDate() + 1);
                    return d;
                  }

                  function getShipInfo() {
                    var t = getNLTime();
                    var nlDay = getNLDay();
                    var isWorkday = nlDay >= 1 && nlDay <= 5;
                    var beforeCutoff = t.hour < cutoffHour;

                    if (isWorkday && beforeCutoff) {
                      var minsLeft = (cutoffHour - t.hour - 1) * 60 + (60 - t.minute);
                      var h = Math.floor(minsLeft / 60);
                      var m = minsLeft % 60;
                      return { countdown: true, hours: h, minutes: m };
                    }
                    return { countdown: false, date: getNextWorkday() };
                  }

                  function render() {
                    var el = document.getElementById('ship-date-text');
                    if (!el) return;
                    var info = getShipInfo();

                    if (info.countdown) {
                      var timeStr = info.hours > 0
                        ? '<span class="ship-countdown">' + info.hours + 'h ' + info.minutes + 'm</span>'
                        : '<span class="ship-countdown">' + info.minutes + 'm</span>';
                      if (isNl) {
                        el.innerHTML = 'Bestel binnen ' + timeStr + ', wordt <span class="ship-date">vandaag</span> verzonden';
                      } else {
                        el.innerHTML = 'Order within ' + timeStr + ', ships <span class="ship-date">today</span>';
                      }
                    } else {
                      var f = formatDate(info.date);
                      if (isNl) {
                        el.innerHTML = 'Voor <strong>15u00</strong> besteld, wordt verzonden op <span class="ship-date">' + f + '</span>';
                      } else {
                        el.innerHTML = 'Ordered before <strong>15hr00</strong>, ships on <span class="ship-date">' + f + '</span>';
                      }
                    }
                    el.style.display = '';
                  }

                  render();
                  // Update countdown every 60s (only ticks when there's a countdown)
                  setInterval(function() {
                    var info = getShipInfo();
                    if (info.countdown) render();
                  }, 60000);
                })();
              </script>

